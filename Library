	local function position_popup(panel, button, align_right)
		local button_position, button_size = get_screen_rect(button)
		local panel_size = panel.AbsoluteSize
		if panel_size.X <= 0 or panel_size.Y <= 0 then
			panel_size = Vector2.new(panel.Size.X.Offset, panel.Size.Y.Offset)
		end

		local viewport = viewport_size()
		local root_offset = window.root.AbsolutePosition
		local x
		local y = button_position.Y - 4

		if align_right then
			panel.AnchorPoint = Vector2.new(1, 1)
			x = button_position.X + button_size.X + 5
		else
			panel.AnchorPoint = Vector2.new(0, 1)
			x = button_position.X
			if button == window.search_button then
				x = x - 5
			end
		end

		if align_right then
			x = clamp(x, panel_size.X + 6, max(panel_size.X + 6, viewport.X - 6))
		else
			x = clamp(x, 6, max(6, viewport.X - panel_size.X - 6))
		end
		y = clamp(y, panel_size.Y + 6, max(panel_size.Y + 6, viewport.Y - 6))
		panel.Position = UDim2.fromOffset(x - root_offset.X, y - root_offset.Y)
	end

	local function position_left_attached_popup(panel, button, extra_y)
		local panel_size = panel.AbsoluteSize
		if panel_size.X <= 0 or panel_size.Y <= 0 then
			panel_size = Vector2.new(panel.Size.X.Offset, panel.Size.Y.Offset)
		end

		local viewport = viewport_size()
		local root_position = window.root.AbsolutePosition
		local button_position, button_size = get_screen_rect(button)
		local vertical_offset = type(extra_y) == "number" and extra_y or 0

		panel.AnchorPoint = Vector2.new(0, 1)

		local x = clamp(root_position.X + 1, 6, max(6, viewport.X - panel_size.X - 6))
		local y = clamp(button_position.Y - 4 + vertical_offset, panel_size.Y + 6, max(panel_size.Y + 6, viewport.Y - 6))
		panel.Position = UDim2.fromOffset(x - root_position.X, y - root_position.Y)
	end

