local function get_screen_rect(gui)
	if not gui or not gui.Parent then
		return Vector2.zero, Vector2.zero
	end

	local size = gui.AbsoluteSize
	local parent_position = gui.Parent.AbsolutePosition
	local parent_size = gui.Parent.AbsoluteSize
	local anchor = gui.AnchorPoint
	local position = gui.Position

	local x = parent_position.X + (parent_size.X * position.X.Scale) + position.X.Offset - (size.X * anchor.X)
	local y = parent_position.Y + (parent_size.Y * position.Y.Scale) + position.Y.Offset - (size.Y * anchor.Y)

	return Vector2.new(x, y), size
end

