local function readPing()
    local ok, value = pcall(function()
        local network = Stats:FindFirstChild("Network")
        local serverStats = network and network:FindFirstChild("ServerStatsItem")
        local dataPing = serverStats and serverStats:FindFirstChild("Data Ping")

        if not dataPing then
            return nil
        end

        local valueString = dataPing:GetValueString()
        return tonumber(string.match(valueString, "[%d%.]+"))
    end)

    if ok then
        return value
    end

    return nil
end

local connections = {}
local destroyed = false
local elapsed = 0
local frames = 0
local pingElapsed = 1
local smoothedFps = 60

connections[#connections + 1] = RunService.RenderStepped:Connect(function(deltaTime)
    if destroyed then
        return
    end

    frames = frames + 1
    elapsed = elapsed + deltaTime
    pingElapsed = pingElapsed + deltaTime

    if elapsed >= 0.4 then
        local measuredFps = frames / elapsed
        smoothedFps = smoothedFps + (measuredFps - smoothedFps) * 0.35
        local fps = math.floor(smoothedFps + 0.5)
        fpsMetric.Text = string.format('<b>%d</b> <font size="7" color="#B7C0CB">fps</font>', fps)
        frames = 0
        elapsed = 0
    end

    if pingElapsed >= 1 then
        local ping = readPing()
        local value = ping and tostring(math.floor(ping + 0.5)) or "--"
        pingMetric.Text = string.format('<b>%s</b> <font size="7" color="#B7C0CB">ms</font>', value)
        pingElapsed = 0
    end
end)

local Watermark = {}

function Watermark:SetTheme(name)
    local themeName = string.lower(tostring(name or ""))
    local resolvedName

    for availableName in pairs(Themes) do
        if string.lower(availableName) == themeName then
            resolvedName = availableName
            break
        end
    end

    if not resolvedName then
        return false
    end

    currentTheme = Themes[resolvedName]
    local sequence = makeThemeSequence(currentTheme)

    panelNeonGradient.Color = sequence
    glowGradient.Color = sequence
    softGlowGradient.Color = sequence
    chromaticWash.BackgroundColor3 = currentTheme.Accent
    washSoftener.Color = ColorSequence.new(currentTheme.Accent)
    washCore.BackgroundColor3 = currentTheme.Accent
    washHalo.BackgroundColor3 = currentTheme.Accent
    emblem.TextColor3 = currentTheme.Accent
    emblemGlow.TextColor3 = currentTheme.Accent

    for _, contour in ipairs(contourStrokes) do
        contour.Stroke.Color = currentTheme.Light
        contour.Glow.Color = currentTheme.Accent
    end

    Config.Theme = resolvedName

    return true
end

function Watermark:GetTheme()
    return Config.Theme
end

function Watermark:Destroy()
    if destroyed then
        return
    end

    destroyed = true

    for _, connection in ipairs(connections) do
        connection:Disconnect()
    end

    if contourTween then
        contourTween:Cancel()
    end

    for _, tween in ipairs(neonTweens) do
        tween:Cancel()
    end

    gui:Destroy()
end

return Watermark
