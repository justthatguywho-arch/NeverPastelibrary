	}, kbl_frame)

	local kbl_underline = create("Frame", {
		Position = UDim2.new(0, 6, 0, KBL_HEADER_H),
		Size = UDim2.new(1, -12, 0, 1),
		BackgroundColor3 = KBL_ACCENT,
		BorderSizePixel = 0,
		ZIndex = 4,
	}, kbl_frame)

	local kbl_body = create("Frame", {
		Position = UDim2.fromOffset(8, KBL_HEADER_H + 5),
		Size = UDim2.new(1, -16, 0, 0),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ZIndex = 3,
	}, kbl_frame)

	local kbl_layout = create("UIListLayout", {
		SortOrder = Enum.SortOrder.LayoutOrder,
		Padding = UDim.new(0, KBL_ROW_PAD),
	}, kbl_body)

	-- Drag support for keybind list
	local kbl_drag_input, kbl_drag_start, kbl_start_pos
	connect(window.connections, kbl_frame.InputBegan, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			kbl_drag_input = input
			kbl_drag_start = input.Position
			kbl_start_pos = kbl_holder.Position
		end
	end)

	insert(window._input_changed_hooks, function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement and kbl_drag_input then
			local delta = input.Position - kbl_drag_start
			kbl_holder.Position = UDim2.new(
				kbl_start_pos.X.Scale, kbl_start_pos.X.Offset + delta.X,
				kbl_start_pos.Y.Scale, kbl_start_pos.Y.Offset + delta.Y
			)
		end
	end)

	insert(window._input_ended_hooks, function(input)
		if input == kbl_drag_input then
			kbl_drag_input = nil
		end
	end)

	-- Fade the whole panel in/out; Visible flips only after the fade-out ends
	local function kbl_set_shown(shown)
		if kbl_shown == shown then return end
		kbl_shown = shown
		if shown then
			kbl_holder.Visible = true
			tween(kbl_frame, 0.25, { GroupTransparency = 0 })
		else
			local fade = tween_object(kbl_frame, 0.25, { GroupTransparency = 1 })
			if fade then
				connect(window.connections, fade.Completed, function()
					if not kbl_shown then kbl_holder.Visible = false end
				end)
			else
				kbl_holder.Visible = false
			end
		end
	end

	-- Rows are keyed by bind name and diffed, not rebuilt: removals fade out
	-- smoothly, survivors are reused, and when the LAST bind turns off the rows
	-- stay in place so the whole panel (text included) fades as one piece.
	local kbl_rows_by_name = {}

	local function kbl_destroy_row(row, animated)
		if not (row.frame and row.frame.Parent) then return end
		if not animated then
			row.frame:Destroy()
			return
		end
		-- Fade content AND collapse the row height: UIListLayout reflows every
		-- frame of the tween, so the rows below glide up instead of snapping
		row.frame.ClipsDescendants = true
		tween(row.badge, 0.18, { BackgroundTransparency = 1 })
		tween(row.badge_label, 0.18, { TextTransparency = 1 })
		tween(row.name_label, 0.18, { TextTransparency = 1 })
		local collapse = tween_object(row.frame, 0.18, { Size = UDim2.new(1, 0, 0, 0) })
		if collapse then
			connect(window.connections, collapse.Completed, function()
				if row.frame and row.frame.Parent then row.frame:Destroy() end
			end)
		else
			row.frame:Destroy()
		end
	end

	local function kbl_make_row(entry, order, animate_in)
		local row = create("Frame", {
			Size = UDim2.new(1, 0, 0, KBL_ROW_H),
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			LayoutOrder = order,
			ZIndex = 4,
		}, kbl_body)

		local name_label = create("TextLabel", {
			Position = UDim2.fromOffset(2, 0),
			Size = UDim2.new(1, -62, 1, 0),
			BackgroundTransparency = 1,
			Font = Enum.Font.GothamMedium,
			Text = entry.name,
			TextSize = 11,
			TextColor3 = KBL_TEXT,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextTruncate = Enum.TextTruncate.AtEnd,
			ZIndex = 5,
		}, row)

		local badge_text = entry.mode == "hold" and "Holding" or "Toggled"
		local badge = create("Frame", {
			AnchorPoint = Vector2.new(1, 0.5),
			Position = UDim2.new(1, -2, 0.5, 0),
			Size = UDim2.fromOffset(0, KBL_ROW_H - 4),
			AutomaticSize = Enum.AutomaticSize.X,
			BackgroundColor3 = KBL_ACCENT,
			BorderSizePixel = 0,
			ZIndex = 5,
		}, row)
		round_ui(badge, 4)

		local badge_label = create("TextLabel", {
			Size = UDim2.new(0, 0, 1, 0),
			AutomaticSize = Enum.AutomaticSize.X,
			BackgroundTransparency = 1,
			Font = Enum.Font.GothamMedium,
			Text = badge_text,
			TextSize = 10,
			TextColor3 = rgb(255, 255, 255),
			ZIndex = 6,
		}, badge)
		create("UIPadding", {
			PaddingLeft = UDim.new(0, 6),
			PaddingRight = UDim.new(0, 6),
		}, badge)

		if animate_in then
			name_label.TextTransparency = 1
			badge.BackgroundTransparency = 1
			badge_label.TextTransparency = 1
			tween(name_label, 0.18, { TextTransparency = 0 })
			tween(badge, 0.18, { BackgroundTransparency = 0 })
			tween(badge_label, 0.18, { TextTransparency = 0 })
		end

		return { frame = row, name_label = name_label, badge = badge, badge_label = badge_label }
	end

	local function kbl_refresh()
		local was_shown = kbl_shown

		local active = {}
		for _, entry in ipairs(window._active_binds) do
			if entry.active then active[#active + 1] = entry end
		end
		local count = #active

		-- Last bind switched off: DON'T touch rows or height — the entire
		-- panel fades out with its content. Stale rows are purged invisibly
		-- on the next refresh (panel is hidden by then, so instant destroy).
		if count == 0 or not kbl_master then
			kbl_set_shown(false)
			return
		end

		local keep = {}
		for i, entry in ipairs(active) do
			keep[entry.name] = i
		end

		for name, row in pairs(kbl_rows_by_name) do
			if not keep[name] then
				kbl_rows_by_name[name] = nil
				kbl_destroy_row(row, was_shown)
			end
		end

		for i, entry in ipairs(active) do
			local row = kbl_rows_by_name[entry.name]
			if row and row.frame and row.frame.Parent then
				row.frame.LayoutOrder = i
				row.badge_label.Text = entry.mode == "hold" and "Holding" or "Toggled"
			else
				kbl_rows_by_name[entry.name] = kbl_make_row(entry, i, was_shown)
			end
		end

		local total_height = KBL_HEADER_H + 5 + (count * (KBL_ROW_H + KBL_ROW_PAD)) + 3
		kbl_body.Size = UDim2.new(1, -20, 0, count * (KBL_ROW_H + KBL_ROW_PAD))
		-- Resize the holder; kbl_frame and the glow follow via scale sizing
		if was_shown then
			tween(kbl_holder, 0.2, { Size = UDim2.fromOffset(KBL_W, total_height) })
		else
			kbl_holder.Size = UDim2.fromOffset(KBL_W, total_height)
		end

		kbl_set_shown(true)
	end

	window._kbl_refresh = kbl_refresh
	window._wm_gui = wm_gui
	window._kbl_gui = kbl_gui

	function window:_kbl_add(name, mode, key, is_active)
		for _, entry in ipairs(self._active_binds) do
			if entry.name == name then
				entry.mode = mode
				entry.key = key
				entry.active = is_active == true
				if kbl_master then kbl_refresh() end
				return
			end
		end
		insert(self._active_binds, { name = name, mode = mode, key = key, active = is_active == true })
		if kbl_master then kbl_refresh() end
	end

	function window:_kbl_remove(name)
		for i, entry in ipairs(self._active_binds) do
			if entry.name == name then
				table.remove(self._active_binds, i)
				break
			end
		end
		if kbl_master then kbl_refresh() end
	end

	keybindlist_toggle.on_change(function(active)
		kbl_master = active
		kbl_refresh()
	end)

	-- ========== SETTINGS STATE API ==========
	window._settings_state = {
		get_watermark = function() return watermark_toggle.get() end,
		set_watermark = function(v) watermark_toggle.set(v) end,
		get_keybindlist = function() return keybindlist_toggle.get() end,
		set_keybindlist = function(v) keybindlist_toggle.set(v) end,
		get_wm_position = function() return wm_position end,
		set_wm_position = function(pos)
			if pos == "TopLeft" or pos == "TopRight" then
				wm_position = pos
				wm_pos_index = (pos == "TopLeft") and 2 or 1
				wm_pos_btn.Text = pos
				wm_refresh_position()
			end
		end,
		get_wm_show = function()
			local copy = {}
			for k, v in pairs(wm_show) do copy[k] = v end
			return copy
		end,
		set_wm_show = function(tbl)
			if type(tbl) ~= "table" then return end
			for k, v in pairs(tbl) do
				if wm_show[k] ~= nil then
					wm_show[k] = v == true
					local vis = wm_field_visuals[k]
					if vis then
						if wm_show[k] then
							tween(vis.check, 0.15, { BackgroundColor3 = self.theme.accent })
							tween(vis.stroke, 0.15, { Color = self.theme.accent })
							tween(vis.tick, 0.15, { ImageTransparency = 0 })
						else
							tween(vis.check, 0.15, { BackgroundColor3 = self.theme.bg })
							tween(vis.stroke, 0.15, { Color = self.theme.line })
							tween(vis.tick, 0.15, { ImageTransparency = 1 })
						end
					end
				end
			end
			wm_update_fields_btn_text()
		end,
	}

	return window
end

function Window:PlayIntro()
	local title_text = self.options.Title or "Menu"
	local theme = self.library.theme

	local old_blur = lighting:FindFirstChild("NeverPasteBlur")
	if old_blur then old_blur:Destroy() end

	local blur = create("BlurEffect", {
		Name = "NeverPasteBlur",
		Size = 0,
	}, lighting)

	local intro_gui = create("ScreenGui", {
		Name = "NeverPasteIntro",
		IgnoreGuiInset = true,
		ResetOnSpawn = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		DisplayOrder = 9999,
	}, get_hui)

	local intro = create("Frame", {
		Size = UDim2.fromScale(1, 1),
		BackgroundColor3 = rgb(0, 0, 0),
		BackgroundTransparency = 1,
		ZIndex = 100,
	}, intro_gui)
	create("UIGradient", {
		Rotation = 135,
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, rgb(8, 10, 20)),
			ColorSequenceKeypoint.new(1, rgb(17, 12, 31)),
		}),
	}, intro)

	local letters_holder = create("Frame", {
		BackgroundTransparency = 1,
		AnchorPoint = vec2(0.5, 0.5),
		Position = UDim2.fromScale(0.5, 0.5),
		Size = UDim2.new(1, -80, 0, 100),
		ZIndex = 101,
	}, intro)
	create("UIListLayout", {
		FillDirection = Enum.FillDirection.Horizontal,
		HorizontalAlignment = Enum.HorizontalAlignment.Center,
		VerticalAlignment = Enum.VerticalAlignment.Center,
		SortOrder = Enum.SortOrder.LayoutOrder,
		Padding = dim(0, 2),
	}, letters_holder)

	local first_char = string.sub(title_text, 1, 1)
	local first_bounds = text_service:GetTextSize(first_char, 72, Enum.Font.GothamBold, vec2(1000, 1000))

	local big_letter = create("TextLabel", {
		BackgroundTransparency = 1,
		AnchorPoint = vec2(0.5, 0.5),
		Position = UDim2.fromScale(0.5, 0.5),
		Size = UDim2.fromOffset(first_bounds.X + 100, 74),
		Font = Enum.Font.GothamBold,
		Text = first_char,
		TextColor3 = rgb(255, 255, 255),
		TextSize = 72,
		TextWrapped = true,
		TextTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Center,
		ZIndex = 102,
	}, intro)
	create("UIGradient", {
		Rotation = 90,
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, theme.accent),
			ColorSequenceKeypoint.new(1, rgb(170, 102, 255)),
		}),
	}, big_letter)
	local big_scale = create("UIScale", {
		Scale = 4.25,
	}, big_letter)

	local glyphs = {}
	local letter_padding = 8
	local half = math.ceil(#title_text / 2)
	for i = 1, #title_text do
		local ch = string.sub(title_text, i, i)
		local bounds = text_service:GetTextSize(ch, 72, Enum.Font.GothamBold, vec2(1000, 1000))
		local holder = create("Frame", {
			BackgroundTransparency = 1,
			Size = UDim2.fromOffset(bounds.X + letter_padding, 100),
			LayoutOrder = i,
			ZIndex = 101,
		}, letters_holder)
		local glyph = create("TextLabel", {
			BackgroundTransparency = 1,
			AnchorPoint = vec2(0.5, 0.5),
			Position = i == 1 and UDim2.new(0.5, 0, 0.5, 0) or UDim2.new(0.5, 0, 0.5, 200),
			Size = UDim2.fromOffset(bounds.X + 100, 74),
			Font = Enum.Font.GothamBold,
			Text = ch,
			TextColor3 = rgb(255, 255, 255),
			TextSize = 72,
			TextWrapped = true,
			TextTransparency = 1,
			TextXAlignment = Enum.TextXAlignment.Center,
			ZIndex = 101,
		}, holder)
		create("UIGradient", {
			Rotation = 90,
			Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0, i <= half and theme.accent or rgb(220, 226, 255)),
				ColorSequenceKeypoint.new(1, i <= half and rgb(162, 108, 255) or rgb(160, 118, 255)),
			}),
		}, glyph)
		glyphs[i] = { holder = holder, glyph = glyph }
	end

	tween_object(blur, 0.9, { Size = 52 }, Enum.EasingStyle.Quart)
	local fade_in = tween_object(intro, 0.45, { BackgroundTransparency = 0.28 })
	if fade_in then fade_in.Completed:Wait() end
	task.wait(0.5)

	local first_glyph = glyphs[1]
	local first_center = vec2(
		first_glyph.holder.AbsolutePosition.X + (first_glyph.holder.AbsoluteSize.X / 2),
		first_glyph.holder.AbsolutePosition.Y + (first_glyph.holder.AbsoluteSize.Y / 2) + abs(intro.AbsolutePosition.Y)
	)

	tween_object(big_letter, 0.42, { TextTransparency = 0 })
	tween_object(big_scale, 0.52, { Scale = 1 }, Enum.EasingStyle.Quart)
	task.wait(0.45)

	tween_object(big_letter, 0.35, {
		Position = UDim2.fromOffset(first_center.X, first_center.Y),
	}, Enum.EasingStyle.Quart)
	task.wait(0.5)

	for i, data in ipairs(glyphs) do
		if i > 1 then
			tween_object(data.glyph, 0.65, {
				Position = UDim2.new(0.5, 0, 0.5, 0),
				TextTransparency = 0,
			}, Enum.EasingStyle.Quart)
		end
	end
	task.wait(2.2)

	tween_object(big_letter, 1.2, { TextTransparency = 1 })
	for _, data in ipairs(glyphs) do
		tween_object(data.glyph, 1.2, { TextTransparency = 1 })
	end

	tween_object(blur, 1.2, { Size = 0 })
	local fade_out = tween_object(intro, 1.2, { BackgroundTransparency = 1 })
	if fade_out then fade_out.Completed:Wait() end

	intro_gui:Destroy()
	blur:Destroy()

	self.root.Visible = true
	self.root.BackgroundTransparency = 1
	local root_tw = tween_object(self.root, 0.35, { BackgroundTransparency = 0 }, Enum.EasingStyle.Quart)
	if root_tw then root_tw.Completed:Wait() end
end

function Window:SetVisible(state)
	if not state and self.close_aux_panels then
		self.close_aux_panels()
	end
	if not state and self.current_popup then
		self.current_popup:SetPopupVisible(false)
	end
	self.root.Visible = state
end

function Window:SetUser(name, expire, image)
	self.user_label.Text = name or self.user_label.Text
	self.expire_label.Text = format_expire(expire)
	if image then
		self.profile_icon.Image = image
	end
end

function Window:Destroy()
	if self.close_aux_panels then
		self.close_aux_panels()
	end
	if self.current_popup then
		self.current_popup:SetPopupVisible(false)
		self.current_popup = nil
	end
	for _, connection in ipairs(self.connections) do
		if connection.Connected then
			connection:Disconnect()
		end
	end
	self.connections = {}
	if self.gui then
		self.gui:Destroy()
	end
	if self._wm_gui then
		self._wm_gui:Destroy()
	end
	if self._kbl_gui then
		self._kbl_gui:Destroy()
	end
	if self._kbl_destroy_glass then
		self._kbl_destroy_glass()
	end
	for index, window in ipairs(self.library.windows) do
		if window == self then
			remove(self.library.windows, index)
			break
		end
	end
end

function Window:SelectTab(tab)
	tab = type(tab) == "string" and self.tab_lookup[tab] or tab
	if not tab then
		return
	end

	if self.current_popup and self.current_popup.section and self.current_popup.section.tab ~= tab then
		self.current_popup:SetPopupVisible(false)
	end

	for _, current in ipairs(self.tabs) do
		local active = current == tab
		current.page.Visible = active
		tween(current.button, 0.12, { BackgroundTransparency = active and 0 or 1 })
		tween(current.label, 0.12, { TextColor3 = active and self.library.theme.text or self.library.theme.text_soft })
		tween(current.stroke, 0.12, { Transparency = active and 0.3 or 1 })
		if current.icon then
			tween(current.icon, 0.12, {
				ImageColor3 = active and self.library.theme.accent or self.library.theme.text_soft,
				ImageTransparency = active and 0 or 0.3,
			})
		elseif current.dot then
			tween(current.dot, 0.12, { BackgroundColor3 = active and self.library.theme.accent or self.library.theme.text_soft })
		end
	end

	self.selected = tab
end

function Window:AddTab(options)
	options = normalize(options, "Name")
	local name = options.Name or ("TAB " .. tostring(#self.tabs + 1))
	local column_count = options.Columns == 3 and 3 or 2
	local column_gap = tonumber(options.ColumnGap or options.ColumnSpacing or 13) or 13
	local column_padding_left = tonumber(options.ColumnPaddingLeft or options.ColumnPadding or 14) or 14
	local column_padding_right = tonumber(options.ColumnPaddingRight or options.ColumnPadding or 14) or 14
	local requested_widths = type(options.ColumnWidths) == "table" and options.ColumnWidths or nil

	local tab = setmetatable({
		window = self,
		name = name,
		column_count = column_count,
	}, Tab)

	tab.page = create("Frame", {
		BackgroundTransparency = 1,
		Size = UDim2.fromScale(1, 1),
		Visible = false,
	}, self.body)

	local function create_column(position, size)
		local column = create("ScrollingFrame", {
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Position = position,
			Size = size,
			ScrollBarThickness = 0,
			ScrollBarImageColor3 = self.library.theme.text_soft or rgb(100, 100, 100),
			ScrollBarImageTransparency = 0.4,
			CanvasSize = UDim2.fromOffset(0, 0),
			ScrollingDirection = Enum.ScrollingDirection.Y,
			TopImage = "rbxasset://textures/ui/Scroll/scroll-middle.png",
			BottomImage = "rbxasset://textures/ui/Scroll/scroll-middle.png",
			MidImage = "rbxasset://textures/ui/Scroll/scroll-middle.png",
		}, tab.page)

		local col_layout = create("UIListLayout", {
			SortOrder = Enum.SortOrder.LayoutOrder,
			Padding = UDim.new(0, 8),
		}, column)

		local function _refresh_col_canvas()
			local h = col_layout.AbsoluteContentSize.Y
			column.CanvasSize = UDim2.fromOffset(0, h)
			column.ScrollBarThickness = h > column.AbsoluteSize.Y and 2 or 0
		end
		col_layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(_refresh_col_canvas)
		column:GetPropertyChangedSignal("AbsoluteSize"):Connect(_refresh_col_canvas)

		return column
	end

	if column_count == 3 then
		local left_width = requested_widths and tonumber(requested_widths[1]) or 0
		local middle_width = requested_widths and tonumber(requested_widths[2]) or 0
		local right_width = requested_widths and tonumber(requested_widths[3]) or nil

		if left_width <= 0 or middle_width <= 0 then
			local total_gap = column_gap * 2
			local default_width = floor((722 - column_padding_left - column_padding_right - total_gap) / 3)
			if left_width <= 0 then
				left_width = default_width
			end
			if middle_width <= 0 then
				middle_width = default_width
			end
		end

		local left_x = column_padding_left
		local middle_x = left_x + left_width + column_gap
		local right_x = middle_x + middle_width + column_gap
		tab.columns = {
			Left = create_column(UDim2.fromOffset(left_x, 0), UDim2.new(0, left_width, 1, 0)),
			Middle = create_column(UDim2.fromOffset(middle_x, 0), UDim2.new(0, middle_width, 1, 0)),
			Right = create_column(
				UDim2.fromOffset(right_x, 0),
				right_width and UDim2.new(0, right_width, 1, 0) or UDim2.new(1, -(right_x + column_padding_right), 1, 0)
			),
		}
	else
		local left_width = requested_widths and tonumber(requested_widths[1]) or 238
		if left_width <= 0 then
			left_width = 238
		end
		local right_x = column_padding_left + left_width + column_gap
		tab.columns = {
			Left = create_column(UDim2.fromOffset(column_padding_left, 0), UDim2.new(0, left_width, 1, 0)),
			Right = create_column(UDim2.fromOffset(right_x, 0), UDim2.new(1, -(right_x + column_padding_right), 1, 0)),
		}
	end

	local tab_icon_id = resolve_icon(options.Icon)
	local has_icon = tab_icon_id ~= nil

	tab.button = create("TextButton", {
		Size = UDim2.fromOffset(tab_width(name, has_icon), 24),
		BackgroundColor3 = self.library.theme.panel_soft,
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Text = "",
		AutoButtonColor = false,
		ZIndex = 5,
	}, self.tab_bar)
	round_ui(tab.button, 4)
	tab.stroke = stroke(tab.button, self.library.theme.line, 1, 1)

	if has_icon then
		tab.icon = create("ImageLabel", {
			AnchorPoint = Vector2.new(0, 0.5),
			Position = UDim2.new(0, 7, 0.5, 0),
			Size = UDim2.fromOffset(14, 14),
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Image = tab_icon_id,
			ImageColor3 = self.library.theme.text_soft,
			ImageTransparency = 0.3,
			ScaleType = Enum.ScaleType.Fit,
			ZIndex = 6,
		}, tab.button)
		round_ui(tab.icon, 2)
		tab.dot = nil
	else
		tab.icon = nil
		tab.dot = create("Frame", {
			AnchorPoint = Vector2.new(0, 0.5),
			Position = UDim2.new(0, 7, 0.5, 0),
			Size = UDim2.fromOffset(7, 7),
			BackgroundColor3 = self.library.theme.text_soft,
			BorderSizePixel = 0,
			ZIndex = 6,
			Name = rand_name(),
		}, tab.button)
		round_ui(tab.dot, 999)
	end

	local label_x = has_icon and 25 or 18
	tab.label = create("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(label_x, 0),
		Size = UDim2.new(1, -(label_x + 4), 1, 0),
		Font = Enum.Font.GothamBold,
		Text = name,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextColor3 = self.library.theme.text_soft,
		ZIndex = 6,
	}, tab.button)

	connect(self.connections, tab.button.MouseEnter, function()
		if self.selected ~= tab then
			tween(tab.button, 0.12, { BackgroundTransparency = 0.25 })
			tween(tab.label, 0.12, { TextColor3 = self.library.theme.text })
			tween(tab.stroke, 0.12, { Transparency = 0.65 })
			if tab.icon then
				tween(tab.icon, 0.12, { ImageColor3 = self.library.theme.text, ImageTransparency = 0.1 })
			end
		end
	end)

	connect(self.connections, tab.button.MouseLeave, function()
		if self.selected ~= tab then
			tween(tab.button, 0.12, { BackgroundTransparency = 1 })
			tween(tab.label, 0.12, { TextColor3 = self.library.theme.text_soft })
			tween(tab.stroke, 0.12, { Transparency = 1 })
			if tab.icon then
				tween(tab.icon, 0.12, { ImageColor3 = self.library.theme.text_soft, ImageTransparency = 0.3 })
			end
		end
	end)

	connect(self.connections, tab.button.MouseButton1Click, function()
		self:SelectTab(tab)
	end)

	self.tab_lookup[name] = tab
	table.insert(self.tabs, tab)
	if not self.selected then
		self:SelectTab(tab)
	end
	return tab
end

function Tab:Select()
	self.window:SelectTab(self)
end

