	insert(self.window._input_began_hooks, function(input, typing)
		local toggle_tab = toggle.section and toggle.section.tab
		local is_on_active_tab = not toggle_tab or toggle_tab == toggle.window.selected

		if input.UserInputType == Enum.UserInputType.MouseButton2 and is_on_active_tab then
			local point = picker_input_position()
			if point_inside(toggle.switch, point) or point_inside(toggle.slot, point) then
				toggle:SetPopupVisible(not toggle.popup_open)
				return
			end
		end

		local is_mouse_button = tostring(input.UserInputType):find("MouseButton") ~= nil
		local point = is_mouse_button and uis:GetMouseLocation() or nil
		local token = bind_token(input)

		if toggle.binding then
			return
		end

		if is_mouse_button and is_on_active_tab and point_inside(toggle.hitbox, point) then
			return
		end

		if not token then
			return
		end

		local mgr = toggle._scope_manager
		if mgr and mgr.scope_values and mgr.flag_entries and mgr.flag_entries[toggle.flag] then
			local original_scope = mgr.active_scope_key

			-- Helper: check if serialized scope data has a matching bind
			local function scope_has_bind(stored, tk)
				if type(stored) ~= "table" then return nil end
				local stored_binds = stored.binds
				if stored_binds then
					for _, sb in ipairs(stored_binds) do
						local dk = deserialize_enum_item(sb.key or sb.Key)
						if dk and dk == tk then
							return normalize_bind_mode(sb.mode or sb.Mode, "toggle")
						end
					end
				end
				local sb = stored.bind
				if sb and sb ~= "none" then
					local dk = deserialize_enum_item(sb)
					if dk and dk == tk then
						return normalize_bind_mode(stored.mode, "toggle")
					end
				end
				return nil
			end

			-- 1) Active scope: use live binds
			local active_matched = false
			for _, bind in ipairs(toggle.binds) do
				if token == bind.key then
					if bind.mode == "toggle" then
						toggle:Toggle()
					elseif bind.mode == "hold" or bind.mode == "always" then
						toggle:Set(true)
					end
					active_matched = true
					break
				end
			end

			-- Snapshot active scope after toggling so its new state is persisted
			if active_matched then
				mgr:_snapshot_controls()
			end

			-- 2) All other scopes: check serialized binds
			for scope_key, bucket in pairs(mgr.scope_values) do
				if scope_key ~= original_scope then
					local mode = scope_has_bind(bucket[toggle.flag], token)
					if mode then
						mgr.active_scope_key = scope_key
						mgr:_load_controls(false)
						if mode == "toggle" then
							toggle:Toggle()
						elseif mode == "hold" or mode == "always" then
							toggle:Set(true)
						end
						mgr:_snapshot_controls()
					end
				end
			end

			-- 3) Restore original scope
			if mgr.active_scope_key ~= original_scope then
				mgr.active_scope_key = original_scope
				mgr:_load_controls(false)
			end
		else
			for _, bind in ipairs(toggle.binds) do
				if token == bind.key then
					if bind.mode == "toggle" then
						toggle:Toggle()
					elseif bind.mode == "hold" then
						toggle:Set(true)
					elseif bind.mode == "always" then
						toggle:Set(true)
					end
					break
				end
			end
		end
	end)

	insert(self.window._input_ended_hooks, function(input)
		local token = bind_token(input)
		if not token then
			return
		end

		local mgr = toggle._scope_manager
		if mgr and mgr.scope_values and mgr.flag_entries and mgr.flag_entries[toggle.flag] then
			local original_scope = mgr.active_scope_key

			-- Helper: check if serialized scope data has a matching hold bind
			local function scope_has_hold(stored, tk)
				if type(stored) ~= "table" then return false end
				local stored_binds = stored.binds
				if stored_binds then
					for _, sb in ipairs(stored_binds) do
						local dk = deserialize_enum_item(sb.key or sb.Key)
						local mode = normalize_bind_mode(sb.mode or sb.Mode, "toggle")
						if dk and dk == tk and mode == "hold" then return true end
					end
				end
				if stored.bind and stored.bind ~= "none" then
					local dk = deserialize_enum_item(stored.bind)
					local mode = normalize_bind_mode(stored.mode, "toggle")
					if dk and dk == tk and mode == "hold" then return true end
				end
				return false
			end

			-- 1) Active scope: use live binds
			local active_matched = false
			for _, bind in ipairs(toggle.binds) do
				if bind.mode == "hold" and bind.key == token then
					toggle:Set(false)
					active_matched = true
					break
				end
			end

			if active_matched then
				mgr:_snapshot_controls()
			end

			-- 2) All other scopes
			for scope_key, bucket in pairs(mgr.scope_values) do
				if scope_key ~= original_scope then
					if scope_has_hold(bucket[toggle.flag], token) then
						mgr.active_scope_key = scope_key
						mgr:_load_controls(false)
						toggle:Set(false)
						mgr:_snapshot_controls()
					end
				end
			end

			-- 3) Restore original scope
			if mgr.active_scope_key ~= original_scope then
				mgr.active_scope_key = original_scope
				mgr:_load_controls(false)
			end
		else
			for _, bind in ipairs(toggle.binds) do
				if bind.mode == "hold" and bind.key == token then
					toggle:Set(false)
					break
				end
			end
		end
	end)

	connect(self.window.connections, row_layout:GetPropertyChangedSignal("AbsoluteContentSize"), function()
		row.Size = UDim2.new(1, 0, 0, row_layout.AbsoluteContentSize.Y)
	end)
	connect(self.window.connections, inline_color_layout:GetPropertyChangedSignal("AbsoluteContentSize"), refresh_inline_color_layout)
