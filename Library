local function rand_name(len)
	len = len or random(6, 12)
	local chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
	local buf = {}
	for i = 1, len do
		local idx = random(1, #chars)
		buf[i] = string.sub(chars, idx, idx)
	end
	return concat(buf, "")
end

