local function keybind_full_name(token)
	if token == Enum.UserInputType.MouseButton1 then return "M1" end
	if token == Enum.UserInputType.MouseButton2 then return "M2" end
	if token == Enum.UserInputType.MouseButton3 then return "M3" end
	if typeof(token) == "EnumItem" then
		-- "LeftShift" -> "Left Shift", "CapsLock" -> "Caps Lock"
		return (string.gsub(token.Name, "(%l)(%u)", "%1 %2"))
	end
	return tostring(token)
end

