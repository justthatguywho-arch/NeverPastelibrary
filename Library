		end
		if color_dragging == "sv" or color_dragging == "hue" or color_dragging == "alpha" then
			set_picker_from_input(color_dragging, input)
		end
	end)

	insert(self.window._input_ended_hooks, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			color_dragging = nil
		end
	end)

	if toggle.has_color then
