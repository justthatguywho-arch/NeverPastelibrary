				local value = get_config_entry_value(entry, true)
				if value ~= nil then
					payload.settings[entry.flag] = value
				end
			end
		end

		return apply_config_data(payload, true)
	end

	function window:CreateConfig(name)
		if not self.config_supported then
			return false, "filesystem unavailable"
		end

		local config_name = normalize_config_name(name or get_requested_config_name(false))
		if config_name == "" then
			return false, "config name is empty"
		end

		if config_exists(config_name) then
			return false, "config already exists"
		end

		return self:SaveConfig(config_name)
	end

	function window:SaveConfig(name)
		if not self.config_supported then
			return false, "filesystem unavailable"
		end

		local config_name = normalize_config_name(name or get_requested_config_name(false))
		if config_name == "" then
			return false, "config name is empty"
		end

		ensure_storage_tree(self.storage_root, self.storage_folders)

		local encoded, encode_error = self:ExportConfig(config_name)
		if not encoded then
			return false, encode_error or "failed to encode config"
		end

		local ok, err = pcall(FileApi.writefile, self.config_folder .. "/" .. config_name .. ".cfg", encoded)
		if not ok then
			return false, err or "failed to write config"
		end

		refresh_config_rows(self.config_selected_name, false)
		return true
	end

	function window:LoadConfig(name)
		if not self.config_supported then
			return false, "filesystem unavailable"
		end

		local config_name = normalize_config_name(name or get_requested_config_name(true))
		if config_name == "" then
			return false, "config name is empty"
		end

		local path = self.config_folder .. "/" .. config_name .. ".cfg"
		if FileApi.isfile then
			local ok, exists = pcall(FileApi.isfile, path)
			if ok and not exists then
				return false, "config does not exist"
			end
		end

		local ok, content = pcall(FileApi.readfile, path)
		if not ok then
			return false, "failed to read config"
		end

		local loaded, message = self:ImportConfig(content)
		if not loaded then
			return false, message
		end

		self.config_selected_name = config_name
		refresh_config_rows(config_name, false)
		return true
	end

	function window:DeleteConfig(name)
		if not self.config_supported then
			return false, "filesystem unavailable"
		end

		local config_name = normalize_config_name(name or get_requested_config_name(true))
		if config_name == "" then
			return false, "config name is empty"
		end

		local path = self.config_folder .. "/" .. config_name .. ".cfg"
		if FileApi.isfile then
			local ok, exists = pcall(FileApi.isfile, path)
			if ok and not exists then
				return false, "config does not exist"
			end
		end

		local ok, err = pcall(FileApi.delfile, path)
		if not ok then
			return false, err or "failed to delete config"
		end

		if self.config_selected_name == config_name then
			self.config_selected_name = nil
			set_config_input("")
		end
		refresh_config_rows(nil, false)
		return true
	end

