	refresh_config_rows = function(preferred_name, sync_name_box)
		local typed = normalize_config_name(config_input.Text)
		local entries = get_config_entries()
		local names = {}
		for _, entry in ipairs(entries) do
			insert(names, entry.name)
		end
		local selected = preferred_name

		if selected == nil or selected == "" or not find(names, selected) then
			selected = window.config_selected_name
		end
		if selected ~= nil and selected ~= "" and not find(names, selected) then
			selected = nil
		end

		window.config_selected_name = selected

		if sync_name_box and selected then
			set_config_input(selected)
			typed = selected
		end

		clear_config_rows()

		local visible_names = {}
		local filter = string.lower(typed)
		for _, config_entry in ipairs(entries) do
			local haystack = string.lower(concat({
				config_entry.name,
				tostring(config_entry.meta and (config_entry.meta.user or config_entry.meta.username) or ""),
				tostring(config_entry.meta and config_entry.meta.updated or ""),
				tostring(config_entry.meta and (config_entry.meta.version_name or config_entry.meta.config_version or config_entry.meta.version) or ""),
			}, " "))
			if filter == "" or string.find(haystack, filter, 1, true) then
				insert(visible_names, config_entry.name)
				create_config_row(config_entry)
			end
		end

		for _, row in ipairs(window.config_rows) do
			row.label.TextColor3 = row.name == selected and self.theme.accent or self.theme.text
		end

		if not window.config_supported then
			config_empty.Text = "filesystem unavailable"
			config_empty.Visible = true
		elseif #visible_names == 0 then
			config_empty.Text = typed ~= "" and "not found" or "no configs"
			config_empty.Visible = true
		else
			config_empty.Visible = false
		end
	end

	local function get_requested_config_name(prefer_selected)
		local selected = normalize_config_name(window.config_selected_name)
		local typed = normalize_config_name(config_input.Text)

		if prefer_selected and selected ~= "" then
			return selected
		end
		if typed ~= "" then
			return typed
		end
		if selected ~= "" then
			return selected
		end
		return nil
	end

	local function apply_config_data(payload, fire_callback)
		if type(payload) ~= "table" then
			return false, "invalid config payload"
		end

		local settings = payload
		if type(payload.settings) == "table" then
			settings = payload.settings
		elseif type(payload.flags) == "table" then
			settings = payload.flags
		end

		if type(settings) ~= "table" then
			return false, "config has no settings"
		end

		for _, entry in ipairs(window.entries) do
			if is_config_entry(entry) then
				local next_value = entry.flag and settings[entry.flag] or nil
				if next_value == nil then
					next_value = get_config_entry_value(entry, true)
				end
				if next_value ~= nil then
					apply_config_entry_value(entry, next_value, fire_callback ~= false)
				end
			end
		end

		-- Restore Settings tab state
		if window._settings_state then
			if settings["__np_watermark"] ~= nil then
				window._settings_state.set_watermark(settings["__np_watermark"])
			end
			if settings["__np_keybindlist"] ~= nil then
				window._settings_state.set_keybindlist(settings["__np_keybindlist"])
			end
			if settings["__np_wm_position"] ~= nil then
				window._settings_state.set_wm_position(settings["__np_wm_position"])
			end
			if settings["__np_wm_show"] ~= nil then
				window._settings_state.set_wm_show(settings["__np_wm_show"])
			end
			if settings["__np_keybind"] ~= nil then
				local ok, key = pcall(function()
					return Enum.KeyCode[settings["__np_keybind"]]
				end)
				if ok and key then
					window.keybind = key
				end
			end
		end

		return true
	end

	local function config_exists(config_name)
		if type(config_name) ~= "string" or config_name == "" then
			return false
		end

		local path = window.config_folder .. "/" .. config_name .. ".cfg"
		if FileApi.isfile then
			local ok, exists = pcall(FileApi.isfile, path)
			if ok then
				return exists == true
			end
		end

		for _, config_entry in ipairs(get_config_entries()) do
			if string.lower(config_entry.name) == string.lower(config_name) then
				return true
			end
		end

		return false
	end

	function window:ExportConfig(name_or_use_defaults)
		local use_defaults = name_or_use_defaults == true
		local config_name = ""
		if type(name_or_use_defaults) == "string" then
			config_name = normalize_config_name(name_or_use_defaults)
		else
			config_name = normalize_config_name(self.config_selected_name or "")
		end
		local payload = {
			meta = {
				name = config_name,
				title = self.options.Title or self.gui_name,
				version = 2,
				version_name = tostring(self.options.ConfigVersion or "1.0.0"),
				user = tostring(self.options.User or "username"),
				updated = format_config_timestamp(),
				directory = self.storage_root,
			},
			settings = {},
		}

		for _, entry in ipairs(self.entries) do
			if is_config_entry(entry) then
				local value = get_config_entry_value(entry, use_defaults)
				if value ~= nil then
					payload.settings[entry.flag] = value
				end
			end
		end

		-- Save Settings tab state
		if self._settings_state then
			payload.settings["__np_watermark"] = self._settings_state.get_watermark()
			payload.settings["__np_keybindlist"] = self._settings_state.get_keybindlist()
			payload.settings["__np_wm_position"] = self._settings_state.get_wm_position()
			payload.settings["__np_wm_show"] = self._settings_state.get_wm_show()
			payload.settings["__np_keybind"] = self.keybind and self.keybind.Name or "Insert"
		end

		local ok, encoded = pcall(function()
			return http_service:JSONEncode(payload)
		end)
		if not ok then
			return nil, "failed to encode config"
		end

		return encoded
	end

	function window:ImportConfig(config_text)
		if type(config_text) ~= "string" or config_text == "" then
			return false, "config text is empty"
		end

		local ok, payload = pcall(function()
			return http_service:JSONDecode(config_text)
		end)
		if not ok or type(payload) ~= "table" then
			return false, "failed to decode config"
		end

		return apply_config_data(payload, true)
	end

