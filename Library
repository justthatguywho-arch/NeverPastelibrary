local function makeThemeSequence(theme)
    return ColorSequence.new({
        ColorSequenceKeypoint.new(0, theme.Deep),
        ColorSequenceKeypoint.new(0.25, theme.Accent),
        ColorSequenceKeypoint.new(0.5, theme.Light),
        ColorSequenceKeypoint.new(0.75, theme.Accent),
        ColorSequenceKeypoint.new(1, theme.Deep),
    })
end

