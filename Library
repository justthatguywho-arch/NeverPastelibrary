	local function read_config_meta(path)
		local ok, content = pcall(FileApi.readfile, path)
		if not ok or type(content) ~= "string" or content == "" then
			return {}
		end

		local payload
		local decoded_ok, decoded = pcall(function()
			return http_service:JSONDecode(content)
		end)
		if decoded_ok and type(decoded) == "table" then
			payload = decoded
		end
		return type(payload) == "table" and type(payload.meta) == "table" and payload.meta or {}
	end

	local function get_config_entries()
		if not window.config_supported then
			return {}
		end

		ensure_storage_tree(window.storage_root, window.storage_folders)

		local ok, files = pcall(FileApi.listfiles, window.config_folder)
		if not ok or type(files) ~= "table" then
			return {}
		end

		local entries = {}
		for _, file_path in ipairs(files) do
			local normalized = tostring(file_path):gsub("\\", "/")
			local name = normalized:match("([^/]+)%.cfg$")
			if name then
				insert(entries, {
					name = name,
					path = normalized,
					meta = read_config_meta(normalized),
				})
			end
		end

		table.sort(entries, function(left, right)
			return string.lower(left.name) < string.lower(right.name)
		end)

		return entries
	end

