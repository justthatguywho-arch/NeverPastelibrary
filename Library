	-- ===== iOS frosted-glass backdrop (acrylic technique) =====
	-- Plain Glass barely blurs. The trick (used by Acrylic/Fluent UIs): a
	-- near-invisible Glass part (Transparency 0.98) still WRITES DEPTH, so
	-- pixels behind it get depth ~= the glass distance (0.5 studs). A
	-- DepthOfFieldEffect tuned to blur only near-camera depths then blurs
	-- exactly the region covered by the glass — the rest of the scene sits
	-- inside the in-focus window and stays sharp. Requires graphics quality
	-- ~8+; below that Roblox skips glass depth-write and you get plain tint.
	local kbl_glass = nil
	local kbl_dof = nil
	local function kbl_ensure_glass()
		if kbl_glass and kbl_glass.Parent then return kbl_glass end
		local ok, part = pcall(function()
			local p = Instance.new("Part")
			p.Name = "np_kbl_glass"
			p.Anchored = true
			p.CanCollide = false
			p.CanQuery = false
			p.CanTouch = false
			p.CastShadow = false
			p.Material = Enum.Material.Glass
			p.Color = Color3.fromRGB(0, 0, 0)
			p.Transparency = 0.98
			p.Reflectance = 0
			p.Size = Vector3.new(0.1, 0.1, 0.01)
			return p
		end)
		if not ok then return nil end
		kbl_glass = part
		return part
	end

	local function kbl_ensure_dof()
		if kbl_dof and kbl_dof.Parent then return kbl_dof end
		local ok, effect = pcall(function()
			local e = Instance.new("DepthOfFieldEffect")
			e.Name = "np_kbl_acrylic"
			e.FarIntensity = 0
			e.FocusDistance = 51.6
			e.InFocusRadius = 50
			e.NearIntensity = 0
			e.Parent = game:GetService("Lighting")
			return e
		end)
		if not ok then return nil end
		kbl_dof = effect
		return effect
	end

	local kbl_cam_conn = nil

	local function kbl_destroy_glass()
		if kbl_glass then
			pcall(function() kbl_glass:Destroy() end)
			kbl_glass = nil
