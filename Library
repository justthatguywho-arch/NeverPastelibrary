local function trim_string(value)
	return tostring(value or ""):gsub("^%s+", ""):gsub("%s+$", "")
end

local function normalize_config_name(name)
	local cleaned = trim_string(name)
	cleaned = cleaned:gsub("[\\/:*?\"<>|]", "")
	cleaned = cleaned:gsub("%s+", " ")
	return cleaned
end

local function normalize_folder_path(path)
	local cleaned = tostring(path or ""):gsub("\\", "/")
	cleaned = trim_string(cleaned):gsub("^/+", ""):gsub("/+$", "")
	if cleaned == "" then
		return nil
	end

	local segments = {}
	for segment in string.gmatch(cleaned, "[^/]+") do
		local normalized = normalize_config_name(segment)
		if normalized ~= "" then
			insert(segments, normalized)
		end
	end

	return #segments > 0 and concat(segments, "/") or nil
end

local function build_storage_folders(folders)
	local results = {}
	local seen = {}

	if type(folders) == "table" then
		for _, folder in ipairs(folders) do
			local normalized = normalize_folder_path(folder)
			local key = normalized and string.lower(normalized) or nil
			if key and not seen[key] then
				seen[key] = true
				insert(results, normalized)
			end
		end
	end

	if not seen["configs"] and not seen["config"] then
		insert(results, 1, "configs")
	end

	return results
end

local function resolve_config_folder(storage_root, folders)
	for _, folder in ipairs(folders or {}) do
		local key = string.lower(folder)
		if key == "configs" or key == "config" then
			return storage_root .. "/" .. folder
		end
	end

	return storage_root .. "/configs"
end

