normalize_alpha = function(alpha_value, transparency_value, fallback)
	if alpha_value ~= nil then
		return clamp(alpha_value, 0, 1)
	end
	if transparency_value ~= nil then
		return clamp(1 - transparency_value, 0, 1)
	end
	return clamp(fallback or 1, 0, 1)
end

local function alpha_to_transparency(alpha_value)
	return 1 - clamp(alpha_value or 1, 0, 1)
end

local function infer_precision(step, explicit_precision)
	if type(explicit_precision) == "number" then
		return max(0, floor(explicit_precision))
	end

	if type(step) ~= "number" then
		return 0
	end

	local normalized = string.match(string.format("%.10f", step), "^[^%.]+%.?(.-)0*$") or ""
	return #normalized
end

local function quantize_number(value, minimum, maximum, step, precision)
	local min_value = tonumber(minimum) or 0
	local max_value = tonumber(maximum)
	if max_value == nil then
		max_value = min_value
	end
	if max_value < min_value then
		min_value, max_value = max_value, min_value
	end

	local numeric = tonumber(value) or min_value
	local increment = tonumber(step) or 1
	if increment <= 0 then
		increment = 1
	end

	local clamped = clamp(numeric, min_value, max_value)
	clamped = min_value + round((clamped - min_value) / increment) * increment
	clamped = clamp(clamped, min_value, max_value)

	local digits = max(0, precision or 0)
	if digits > 0 then
		local factor = 10 ^ digits
		clamped = round(clamped * factor) / factor
	else
		clamped = round(clamped)
	end

	return clamped
end

local function format_number(value, precision)
	local digits = max(0, precision or 0)
	if digits <= 0 then
		return tostring(round(tonumber(value) or 0))
	end

	return string.format("%." .. tostring(digits) .. "f", tonumber(value) or 0)
end

local function normalize_dropdown_values(values)
	if type(values) ~= "table" then
		return {}
	end

	local normalized = {}
	for _, value in ipairs(values) do
		if value ~= nil then
			insert(normalized, tostring(value))
		end
	end

	if #normalized > 0 then
		return normalized
	end

	local unsorted = {}
	for _, value in pairs(values) do
		if value ~= nil then
			insert(unsorted, tostring(value))
		end
	end

	table.sort(unsorted, function(left, right)
		return string.lower(left) < string.lower(right)
	end)

	return unsorted
end

local function list_contains(list, value)
	return list ~= nil and find(list, value) ~= nil
end

local function shallow_copy(value)
	if type(value) ~= "table" then
		return value
	end

	local result = {}
	for key, item in pairs(value) do
		result[key] = item
	end
	return result
end

deep_copy = function(value, seen)
	if type(value) ~= "table" then
		return value
	end

	seen = seen or {}
	if seen[value] then
		return seen[value]
	end

	local result = {}
	seen[value] = result
	for key, item in pairs(value) do
		result[deep_copy(key, seen)] = deep_copy(item, seen)
	end
	return result
end

local function normalize_scope_kind(kind)
	local token = string.lower(trim_string(kind or ""))
	if token == "global" or token == "globals" then
		return "global"
	end
	if token == "category" or token == "categories" then
		return "category"
	end
	if token == "weapon" or token == "weapons" then
		return "weapon"
	end
	return nil
end

local function normalize_scope_id(value)
	local text = trim_string(value)
	text = text:gsub("[%c]", "")
	text = text:gsub("%s+", "_")
	text = text:gsub("[^%w_%-%./]", "")
	text = string.lower(text)
	return text ~= "" and text or nil
end

local function scope_kind_rank(kind)
	if kind == "global" then
		return 1
	end
	if kind == "category" then
		return 2
	end
	if kind == "weapon" then
		return 3
	end
	return 99
end

local function make_scope_key(kind, id)
	local normalized_kind = normalize_scope_kind(kind)
	local normalized_id = normalize_scope_id(id or normalized_kind)
	if not normalized_kind or not normalized_id then
		return nil
	end
	return normalized_kind .. ":" .. normalized_id
end

local function build_scope_definition(kind, id, name, category_id, order)
	local normalized_kind = normalize_scope_kind(kind)
	local normalized_id = normalize_scope_id(id or normalized_kind)
	if not normalized_kind or not normalized_id then
		return nil
	end

	local scope = {
		kind = normalized_kind,
		id = normalized_id,
		name = trim_string(name or normalized_id),
		category_id = normalized_kind == "weapon" and normalize_scope_id(category_id) or nil,
		order = tonumber(order) or 0,
	}
	scope.key = make_scope_key(scope.kind, scope.id)
	if scope.name == "" then
		scope.name = normalized_kind == "global" and "Global" or normalized_id
	end
	return scope
end

local function normalize_scope_list(items, kind, start_order)
	local results = {}
	local lookup = {}
	local order = tonumber(start_order) or 0
	local source = {}
	if type(items) == "table" then
		if #items > 0 then
			for _, raw in ipairs(items) do
				insert(source, raw)
			end
		else
			for _, raw in pairs(items) do
				insert(source, raw)
			end
			table.sort(source, function(left, right)
				local left_name = type(left) == "table" and (left.name or left.Name or left.label or left.Label or left.id or left.Id) or tostring(left)
				local right_name = type(right) == "table" and (right.name or right.Name or right.label or right.Label or right.id or right.Id) or tostring(right)
				return string.lower(tostring(left_name)) < string.lower(tostring(right_name))
			end)
		end
	end

	for _, raw in ipairs(source) do
		order = order + 1
		local entry_kind = kind
		local id
		local name
		local category_id

		if type(raw) == "table" then
			entry_kind = normalize_scope_kind(raw.kind or raw.Kind or kind) or kind
			id = raw.id or raw.Id or raw.key or raw.Key or raw.value or raw.Value or raw.name or raw.Name
			name = raw.name or raw.Name or raw.label or raw.Label or raw.text or raw.Text or id
			category_id = raw.category or raw.Category or raw.category_id or raw.CategoryId
		else
			id = raw
			name = raw
		end

		local scope = build_scope_definition(entry_kind, id, name, category_id, order)
		if scope and not lookup[scope.key] then
			lookup[scope.key] = scope
			insert(results, scope)
		end
	end
	return results, lookup, order
end

local function normalize_scope_catalog(catalog)
	local source = type(catalog) == "table" and catalog or {}
	local global_name = source.GlobalName or source.global_name or source.Global or source.global or "Global"
	local global_scope = build_scope_definition("global", "global", global_name, nil, 0)

	local categories, category_lookup, last_order = normalize_scope_list(
		source.Categories or source.categories,
		"category",
		0
	)
	local weapons, weapon_lookup = normalize_scope_list(
		source.Weapons or source.weapons,
		"weapon",
		last_order
	)

	local by_key = {}
	local weapon_to_category = {}
	by_key[global_scope.key] = global_scope

	for _, category in ipairs(categories) do
		by_key[category.key] = category
	end

	for _, weapon in ipairs(weapons) do
		by_key[weapon.key] = weapon
		if weapon.category_id then
			weapon_to_category[weapon.id] = weapon.category_id
		end
	end

	return {
		global = global_scope,
		categories = categories,
		category_lookup = category_lookup,
		weapons = weapons,
		weapon_lookup = weapon_lookup,
		weapon_to_category = weapon_to_category,
		by_key = by_key,
	}
end

local function normalize_dropdown_selection(values, selection, is_multi)
	local normalized_values = normalize_dropdown_values(values)
	local lookup = {}
	for _, value in ipairs(normalized_values) do
		lookup[value] = true
	end

	if is_multi then
		local selected = {}
		if type(selection) == "table" then
			local has_array = #selection > 0
			if has_array then
				for _, value in ipairs(selection) do
					local token = tostring(value)
					if lookup[token] then
						selected[token] = true
					end
				end
			else
				for key, value in pairs(selection) do
					if value == true then
						local token = tostring(key)
						if lookup[token] then
							selected[token] = true
						end
					elseif value ~= nil then
						local token = tostring(value)
						if lookup[token] then
							selected[token] = true
						end
					end
				end
			end
		elseif selection ~= nil then
			local token = tostring(selection)
			if lookup[token] then
				selected[token] = true
			end
		end

		return selected
	end

	if selection == nil then
		return nil
	end

	local token = tostring(selection)
	return lookup[token] and token or nil
end

local function dropdown_selection_list(values, selection)
	local result = {}
	if type(selection) ~= "table" then
		return result
	end

	for _, value in ipairs(normalize_dropdown_values(values)) do
		if selection[value] then
			insert(result, value)
		end
	end

	return result
end

local function disconnect(bucket, connection)
	if not connection then
		return
	end
	if connection.Connected then
		connection:Disconnect()
	end
	if bucket then
		for index = #bucket, 1, -1 do
			if bucket[index] == connection then
				remove(bucket, index)
				break
			end
		end
	end
end

