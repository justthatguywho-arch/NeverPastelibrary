local function create(class_name, props, parent)
	local instance = Instance.new(class_name)
	local has_name = false
	for key, value in next, props or {} do
		if key == "Name" then has_name = true end
		instance[key] = value
	end
	if not has_name then
		instance.Name = rand_name()
	end
	instance.Parent = parent
	return instance
end

local function bump_zindex(root, delta)
	if root:IsA("GuiObject") then
		root.ZIndex = root.ZIndex + delta
