	local function get_popup_anchor_rect()
		local anchor_gui = toggle.switch or toggle.slot or toggle.hitbox
		return anchor_gui.AbsolutePosition, anchor_gui.AbsoluteSize
	end

	local function bind_display_text(token, listening)
		if listening then
			return "..."
		end
		if not token or token == "none" then
			return "+"
		end
		if token == Enum.UserInputType.MouseButton1 then
			return "M1"
		end
		if token == Enum.UserInputType.MouseButton2 then
			return "M2"
		end
		if token == Enum.UserInputType.MouseButton3 then
			return "M3"
		end
		if typeof(token) == "EnumItem" and token.EnumType == Enum.KeyCode then
			local aliases = {
				LeftShift = "LS",
				RightShift = "RS",
				LeftControl = "LC",
				RightControl = "RC",
				LeftAlt = "LA",
				RightAlt = "RA",
				Insert = "INS",
				Backspace = "BSP",
				Return = "ENT",
				Escape = "ESC",
				Space = "SPC",
			}
			return aliases[token.Name] or string.upper(token.Name)
		end
		return string.upper(tostring(token))
	end

	local function clone_binds()
		local result = {}
		for index, bind in ipairs(toggle.binds) do
			result[index] = {
				key = bind.key,
				mode = bind.mode,
			}
		end
		return result
	end

	local function refresh_primary_bind()
		local primary = toggle.binds[1]
		toggle.bind.key = primary and primary.key or "none"
		toggle.bind.mode = primary and primary.mode or default_bind_mode
	end

	local function sync_flags()
		refresh_primary_bind()
		local cloned_binds = clone_binds()
		toggle.value.enabled = state
		toggle.value.key = toggle.bind.key
		toggle.value.mode = toggle.bind.mode
		toggle.value.binds = cloned_binds

		toggle.bind_flag.Key = toggle.bind.key
		toggle.bind_flag.Mode = toggle.bind.mode
		toggle.bind_flag.Binds = clone_binds()

		toggle.library.flags[toggle.flag] = state
		toggle.library.flags[toggle.flag .. "_bind"] = toggle.bind_flag
		toggle.library.flags[toggle.flag .. "_options"] = toggle.value
	end

	local function sync_keybind_list_state()
		local first_key = nil
		local key_parts = {}
		for _, bind in ipairs(toggle.binds) do
			if bind.key and bind.key ~= "none" then
				local full = keybind_full_name(bind.key)
				if not first_key then first_key = full end
				key_parts[#key_parts + 1] = full
			end
		end

		if #key_parts > 0 and toggle.window._kbl_add then
			-- "[Space + H]" style for multi-key binds, "[F]" for single.
			-- toggle.name is the feature's Name ("Rapid Fire"), NOT self.name —
			-- this closure lives in Section:AddToggle where self is the section.
			toggle.window:_kbl_add(toggle.name, toggle.bind.mode, concat(key_parts, " + "), state == true)
		elseif toggle.window._kbl_remove then
			toggle.window:_kbl_remove(toggle.name)
		end
	end

	local function refresh_mode_dropdown_position()
		if not mode_dropdown.Visible then
			return
		end

		local current_row = active_mode_bind_index and bind_rows[active_mode_bind_index] or nil
		if not current_row or not current_row.frame.Visible then
			mode_dropdown.Visible = false
			active_mode_bind_index = nil
			return
		end

		local viewport = viewport_size()
		local root_pos = self.window.root.AbsolutePosition
		local button_pos = current_row.mode_button.AbsolutePosition
		local x = clamp(button_pos.X, 6, max(6, viewport.X - mode_dropdown.AbsoluteSize.X - 6))
		local y = clamp(button_pos.Y + current_row.mode_button.AbsoluteSize.Y + 4, 6, max(6, viewport.Y - mode_dropdown.AbsoluteSize.Y - 6))
		mode_dropdown.Position = UDim2.fromOffset(x - root_pos.X, y - root_pos.Y)
	end

	local function set_mode_dropdown_visible(value, bind_index)
		if bind_index ~= nil then
			active_mode_bind_index = bind_index
		elseif value ~= true then
			active_mode_bind_index = nil
		end

		local open = value == true
			and toggle.popup_open
			and active_mode_bind_index ~= nil
			and toggle.binds[active_mode_bind_index] ~= nil
		mode_dropdown.Visible = open
		if open then
			refresh_mode_dropdown_position()
		end
	end

	local function refresh_mode_buttons()
		local current_mode = active_mode_bind_index and toggle.binds[active_mode_bind_index] and toggle.binds[active_mode_bind_index].mode or nil

		for name, entry in pairs(toggle.mode_buttons) do
			local active = name == current_mode
			tween(entry.button, 0.12, {
				BackgroundTransparency = active and 0.2 or 1,
				TextColor3 = active and toggle.library.theme.accent or toggle.library.theme.text_soft,
			})
		end
	end

	local function refresh_bind_controls()
		bind_rows_holder.Size = UDim2.new(1, 0, 0, #toggle.binds > 0 and ((#toggle.binds * 24) + ((#toggle.binds - 1) * bind_rows_layout.Padding.Offset)) or 0)

		for index, row in ipairs(bind_rows) do
			local bind = toggle.binds[index]
			local visible = bind ~= nil
			row.frame.Visible = visible
			row.frame.Size = UDim2.new(1, 0, 0, visible and 24 or 0)

			if visible then
				row.key_button.Text = bind_display_text(bind.key, toggle.binding and toggle.binding_index == index)
				row.key_button.TextColor3 = toggle.binding and toggle.binding_index == index and toggle.library.theme.accent or toggle.library.theme.text
				row.delete_button.ImageTransparency = 0.05
				row.mode_button.Visible = true
				row.key_button.Visible = true
				row.delete_button.Visible = true
				row.mode_label.Text = bind.mode == "hold" and "Hold" or "Toggle"
				row.mode_label.TextColor3 = active_mode_bind_index == index and toggle.library.theme.accent or toggle.library.theme.text_soft
				row.mode_arrow.Text = mode_dropdown.Visible and active_mode_bind_index == index and "^" or "v"
				row.mode_arrow.TextColor3 = active_mode_bind_index == index and mode_dropdown.Visible and toggle.library.theme.accent or toggle.library.theme.text_soft
			end
		end

		if #toggle.binds == 0 then
			set_mode_dropdown_visible(false)
		end

		local can_add_more = #toggle.binds < 3
		tween(bind_button, 0.12, {
			BackgroundColor3 = can_add_more and toggle.library.theme.panel or toggle.library.theme.panel_soft,
			TextColor3 = can_add_more and toggle.library.theme.text_soft or toggle.library.theme.text_soft,
		})
		bind_button.TextTransparency = can_add_more and 0 or 0.45
		bind_button.Text = can_add_more and "Add hotkey" or "3 hotkeys max"

		refresh_mode_buttons()
	end

	local function refresh_popup_position()
		local viewport = viewport_size()
		local root_pos = self.window.root.AbsolutePosition
		local anchor_pos, anchor_size = get_popup_anchor_rect()
		local abs_x = anchor_pos.X + anchor_size.X + 8
		local abs_y = anchor_pos.Y - 4
		if abs_x + popup_width > viewport.X - 6 then
			abs_x = anchor_pos.X - popup_width - 8
		end
		abs_x = clamp(abs_x, 6, max(6, viewport.X - popup_width - 6))
		abs_y = clamp(abs_y, 6, max(6, viewport.Y - popup_height - 6))
		popup.Position = UDim2.fromOffset(abs_x - root_pos.X, abs_y - root_pos.Y)
		refresh_mode_dropdown_position()
	end

	local function refresh_popup_height()
		popup_height = popup_layout.AbsoluteContentSize.Y + popup_padding.PaddingTop.Offset + popup_padding.PaddingBottom.Offset
		popup_width = has_color and 178 or 190
		popup_overlay.Visible = toggle.popup_open
		popup.Visible = toggle.popup_open
		popup.Size = UDim2.fromOffset(popup_width, toggle.popup_open and popup_height or 0)
		popup.BackgroundTransparency = toggle.popup_open and 0 or 1
		popup_stroke.Transparency = toggle.popup_open and 0.15 or 1
		if toggle.popup_open then
			refresh_popup_position()
		else
			set_mode_dropdown_visible(false)
		end
	end

	local function refresh_picker()
		if not toggle.has_color then
			return
		end
		local color = hsv(hue, sat, val)
		sv_picker.BackgroundColor3 = hsv(hue, 1, 1)
		sv_cursor.Position = dim2(sat, 0, 1 - val, 0)
		hue_cursor.Position = dim2(0.5, 0, hue, 0)
		alpha_cursor.Position = dim2(toggle.bind.alpha, 0, 0.5, 0)
		alpha_gradient.BackgroundColor3 = color
		swatch_fill.BackgroundColor3 = color
		swatch_fill.BackgroundTransparency = 1 - toggle.bind.alpha
		if toggle._hex_label then
			toggle._hex_label.Text = "#" .. color:ToHex():upper()
		end
	end

	function toggle:SetPopupVisible(value)
		self.popup_open = value == true
		if self.popup_open then
			if self.window.current_popup and self.window.current_popup ~= self then
				self.window.current_popup:SetPopupVisible(false)
			end
			self.window.current_popup = self
		else
			if self.window.current_popup == self then
				self.window.current_popup = nil
			end
			set_mode_dropdown_visible(false)
			disconnect(self.window.connections, self.binding_connection)
			self.binding_connection = nil
			self.binding = false
			self.binding_index = nil
		end
		refresh_bind_controls()
		refresh_popup_height()
	end

	function toggle:SetBind(token, bind_index)
		local index = tonumber(bind_index) or 1
		if token == Enum.KeyCode.Escape or token == Enum.KeyCode.Backspace then
			token = "none"
		end

		if token == nil then
			token = "none"
		end

		if token == "none" then
			if self.binds[index] then
				remove(self.binds, index)
			end
		else
			local bind = self.binds[index]
			if bind == nil and index <= 3 then
				bind = {
					key = token,
					mode = default_bind_mode,
				}
				self.binds[index] = bind
			end
			if bind then
				bind.key = token
				bind.mode = normalize_bind_mode(bind.mode, default_bind_mode)
			end
		end

		if toggle.binding_index == index and (self.binds[index] == nil or token == "none") then
			self.binding = false
			self.binding_index = nil
			disconnect(self.window.connections, self.binding_connection)
			self.binding_connection = nil
		end

		refresh_primary_bind()
		if self.bind.mode == "hold" and self.bind.key == "none" and state then
			self:Set(false)
		end
		refresh_bind_controls()
		if self.popup_open then
			refresh_popup_height()
		end
		sync_flags()
		sync_keybind_list_state()
	end

	function toggle:SetBinds(binds)
		local source_binds = {}
		for _, bind in ipairs(binds or {}) do
			insert(source_binds, bind)
		end

		table.clear(self.binds)
		for _, bind in ipairs(source_binds) do
			if #self.binds >= 3 then
				break
			end
			local token = bind and bind.key or bind.Key
			if token and token ~= "none" then
				insert(self.binds, {
					key = token,
					mode = normalize_bind_mode(bind.mode or bind.Mode, default_bind_mode),
				})
			end
		end

		if self.binding_index and self.binds[self.binding_index] == nil then
			self.binding = false
			self.binding_index = nil
			disconnect(self.window.connections, self.binding_connection)
			self.binding_connection = nil
		end

		refresh_primary_bind()
		if self.bind.mode == "hold" and self.bind.key == "none" and state then
			self:Set(false)
		end
		refresh_bind_controls()
		if self.popup_open then
			refresh_popup_height()
		end
		sync_flags()
		sync_keybind_list_state()
	end

	function toggle:SetMode(mode, bind_index)
		local normalized_mode = normalize_bind_mode(mode, default_bind_mode)
		if not valid_modes[normalized_mode] then
			return
		end

		local index = tonumber(bind_index) or 1
		if self.binds[index] then
			self.binds[index].mode = normalized_mode
		else
			default_bind_mode = normalized_mode
		end

		refresh_primary_bind()
		refresh_mode_buttons()
		if self.bind.mode == "always" then
			self:Set(true)
		elseif state and self.bind.mode == "hold" and self.bind.key == "none" then
			self:Set(false)
		end
		sync_flags()
		sync_keybind_list_state()
	end

	function toggle:SetRainbow(value)
		if not self.has_color then
			self.rainbow = false
			sync_flags()
			return
		end
		self.rainbow = value == true
		local button = self.action_buttons.Rainbow
		tween(button, 0.12, {
			BackgroundColor3 = self.rainbow and self.bind.color or self.library.theme.panel_soft,
			TextColor3 = self.rainbow and self.library.theme.text or self.library.theme.text_soft,
		})
		local outline = button:FindFirstChildOfClass("UIStroke")
		if outline then
			tween(outline, 0.12, {
				Transparency = self.rainbow and 0 or 0.35,
				Color = self.rainbow and self.bind.color or self.library.theme.line,
			})
		end
		sync_flags()
	end

	function toggle:SetColor(color, alpha_or_preserve_rainbow, preserve_rainbow, preserve_hsv)
		if not self.has_color then
			return
		end
		local alpha = self.bind.alpha
		if type(alpha_or_preserve_rainbow) == "number" then
			alpha = clamp(alpha_or_preserve_rainbow, 0, 1)
		elseif type(alpha_or_preserve_rainbow) == "boolean" and preserve_rainbow == nil then
			preserve_rainbow = alpha_or_preserve_rainbow
		end

		if not preserve_rainbow then
			self.rainbow = false
		end

		self.bind.color = color
		self.bind.alpha = alpha
		if not preserve_hsv then
			local next_hue, next_sat, next_val = color:ToHSV()
			if next_sat > 0 and next_val > 0 then
				hue = next_hue
			end
			sat, val = next_sat, next_val
		end
		refresh_picker()
		self:SetRainbow(self.rainbow)
		refresh_mode_buttons()
		sync_flags()
	end

	function toggle:SetAlpha(alpha)
		if not self.has_color then
			return
		end
		self:SetColor(self.bind.color, alpha, true, true)
	end

	local function set_sv(point)
		if not toggle.has_color then
			return
		end
		sat = clamp((point.X - sv_picker.AbsolutePosition.X) / max(sv_picker.AbsoluteSize.X, 1), 0, 1)
		val = 1 - clamp((point.Y - sv_picker.AbsolutePosition.Y) / max(sv_picker.AbsoluteSize.Y, 1), 0, 1)
		toggle:SetColor(hsv(hue, sat, val), toggle.bind.alpha, true, true)
	end

	local function set_hue(point)
		if not toggle.has_color then
			return
		end
		hue = clamp((point.Y - hue_picker.AbsolutePosition.Y) / max(hue_picker.AbsoluteSize.Y, 1), 0, 1)
		toggle:SetColor(hsv(hue, sat, val), toggle.bind.alpha, true, true)
	end

	local function set_alpha(point)
		if not toggle.has_color then
			return
		end
		local alpha = clamp((point.X - alpha_row.AbsolutePosition.X) / max(alpha_row.AbsoluteSize.X, 1), 0, 1)
		toggle:SetAlpha(alpha)
	end

	local function set_picker_from_input(mode, input)
		local point = vec2(input.Position.X, input.Position.Y)
		if mode == "sv" then
			set_sv(point)
		elseif mode == "hue" then
			set_hue(point)
		elseif mode == "alpha" then
			set_alpha(point)
		end
	end

	local function begin_picker_drag(target, mode)
		connect(self.window.connections, target.InputBegan, function(input)
			if input.UserInputType ~= Enum.UserInputType.MouseButton1 then
				return
			end

			color_dragging = mode
			set_picker_from_input(mode, input)
		end)
	end

	function toggle:Set(value)
		if self.bind.mode == "always" then
			value = true
		end
		state = value == true
		sync_flags()
		render(state)
		if options.Callback and not self._mute_callback then
			options.Callback(state, self:GetValue())
		end
		sync_keybind_list_state()
		return state
	end

	function toggle:Get()
		return state
	end

	function toggle:Toggle()
		return self:Set(not state)
	end

	function toggle:SetText(value)
		self.label.Text = value
		if self.search_entry then
			self.search_entry.name = value
			refresh_search_entry(self.search_entry)
		end
	end

	function toggle:GetBind()
		return {
			key = self.bind.key,
			mode = self.bind.mode,
		}
	end

	function toggle:GetBinds()
		return clone_binds()
	end

	function toggle:GetValue()
		return self.value
	end

	function toggle:SetVisible(value)
		self.frame.Visible = value
		if not value and self.popup_open then
			self:SetPopupVisible(false)
		end
	end

	connect(self.window.connections, hitbox.MouseEnter, function()
		if not state then
			tween(label, 0.12, { TextColor3 = toggle.library.theme.text })
			tween(switch_stroke, 0.12, { Transparency = 0.05 })
			tween(knob, 0.12, {
				ImageTransparency = 0.5,
				ImageColor3 = toggle.library.theme.text,
				Size = UDim2.fromScale(0.7, 0.7),
				Rotation = 0,
			})
		end
	end)

	connect(self.window.connections, hitbox.MouseLeave, function()
		if not state then
			tween(label, 0.12, { TextColor3 = toggle.library.theme.text_soft })
			tween(switch_stroke, 0.12, { Transparency = 0.15 })
			tween(knob, 0.12, {
				ImageTransparency = 1,
				ImageColor3 = toggle.library.theme.text,
				Size = UDim2.fromScale(0.7, 0.7),
				Rotation = 15,
			})
		end
	end)

	connect(self.window.connections, hitbox.MouseButton1Click, function()
		toggle:Toggle()
	end)

	local function begin_bind_capture(bind_index)
		local index = tonumber(bind_index) or 1
		if not toggle.binds[index] then
			return
		end

		if toggle.binds[index].mode == "always" then
			toggle:SetMode("toggle", index)
		end
		set_mode_dropdown_visible(false)
		disconnect(self.window.connections, toggle.binding_connection)
		toggle.binding = true
		toggle.binding_index = index
		refresh_bind_controls()
		if toggle.popup_open then
			refresh_popup_height()
		end
		toggle.binding_connection = connect(self.window.connections, uis.InputBegan, function(input)
			local token = bind_token(input)
			if not token then
				return
			end

			disconnect(self.window.connections, toggle.binding_connection)
			toggle.binding_connection = nil
			toggle.binding = false
			toggle.binding_index = nil
			toggle:SetBind(token, index)
		end)
	end

	connect(self.window.connections, bind_button.MouseButton1Click, function()
		if #toggle.binds >= 3 then
			return
		end

		insert(toggle.binds, {
			key = "none",
			mode = default_bind_mode,
		})
		refresh_primary_bind()
		refresh_bind_controls()
		refresh_popup_height()
		begin_bind_capture(#toggle.binds)
	end)

	for mode, entry in pairs(mode_buttons) do
		connect(self.window.connections, entry.button.MouseButton1Click, function()
			if active_mode_bind_index then
				toggle:SetMode(mode, active_mode_bind_index)
			end
			set_mode_dropdown_visible(false)
			refresh_mode_buttons()
		end)
	end

	for index, bind_row in ipairs(bind_rows) do
		connect(self.window.connections, bind_row.key_button.MouseButton1Click, function()
			begin_bind_capture(index)
		end)

		connect(self.window.connections, bind_row.mode_button.MouseButton1Click, function()
			if not toggle.binds[index] then
				return
			end
			if toggle.binds[index].mode == "always" then
