function Tab:AddScopeSidebar(options)
	options = normalize(options, "Name")
	local side = options.Side or "Left"
	local minimum_height = options.Height or 405
	local frame_height = max(0, minimum_height)

	local name_token = normalize_scope_id(options.Name or self.name or "scopes") or tostring(random(1000, 999999))
	local sidebar = setmetatable({
		tab = self,
		window = self.window,
		library = self.window.library,
		name = options.Name or "Scopes",
		side = side,
		flag = options.Flag or ("__scope_sidebar_" .. name_token),
		catalog = normalize_scope_catalog(options.Catalog),
		scope_lookup = {},
		scope_values = {},
		bound_controls = {},
		flag_entries = {},
		active_scope_key = nil,
		popup_open = false,
		popup_mode = "category",
		section = { tab = self },
	}, ScopeSidebar)

	sidebar.holder = create("Frame", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, frame_height),
	}, self.columns[side] or self.columns.Left)

	sidebar.frame = create("Frame", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ClipsDescendants = false,
		Position = UDim2.fromOffset(0, 0),
		Size = UDim2.new(1, 0, 0, frame_height),
	}, sidebar.holder)

	sidebar.content = create("Frame", {
		Position = UDim2.fromOffset(0, 0),
		Size = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ClipsDescendants = false,
	}, sidebar.frame)

	sidebar.list_holder = create("Frame", {
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(0, 2),
		Size = UDim2.new(1, 0, 1, -34),
		BorderSizePixel = 0,
	}, sidebar.content)

	sidebar.scope_results = create("ScrollingFrame", {
		Active = true,
		AutomaticCanvasSize = Enum.AutomaticSize.None,
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		CanvasSize = UDim2.fromOffset(0, 0),
		ScrollBarImageColor3 = self.window.library.theme.line,
		ScrollBarImageTransparency = 0.2,
		ScrollBarThickness = 2,
		Size = UDim2.fromScale(1, 1),
	}, sidebar.list_holder)
	sidebar.scope_layout = create("UIListLayout", {
		SortOrder = Enum.SortOrder.LayoutOrder,
		Padding = UDim.new(0, 1),
	}, sidebar.scope_results)

	sidebar.add_button = create("TextButton", {
		AnchorPoint = Vector2.new(0.5, 1),
		Position = UDim2.new(0.5, 0, 1, 0),
		Size = UDim2.new(1, 0, 0, 18),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		AutoButtonColor = false,
		Font = Enum.Font.GothamSemibold,
		Text = "+ Add",
		TextSize = 12,
		TextColor3 = self.window.library.theme.text_soft,
	}, sidebar.content)

	sidebar.popup_overlay = create("TextButton", {
		Visible = false,
		Position = UDim2.fromOffset(-2000, -2000),
		Size = UDim2.fromOffset(6000, 6000),
		BackgroundTransparency = 1,
		Text = "",
		ZIndex = 49,
		Active = true,
	}, self.window.popup_container)

	sidebar.popup = create("Frame", {
		Visible = false,
		Position = UDim2.fromOffset(0, 0),
		Size = UDim2.fromOffset(options.PopupWidth or 160, options.PopupHeight or 170),
		BackgroundColor3 = self.window.library.theme.bg,
		BorderSizePixel = 0,
		ZIndex = 50,
	}, self.window.popup_container)
	round_ui(sidebar.popup, 3)
	stroke(sidebar.popup, self.window.library.theme.line, 0.05, 1)

	sidebar.popup_mode_buttons = {}

	local popup_search_shell = create("Frame", {
		BackgroundColor3 = self.window.library.theme.panel,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(8, 8),
		Size = UDim2.new(1, -16, 0, 24),
	}, sidebar.popup)
	round_ui(popup_search_shell, 3)
	stroke(popup_search_shell, self.window.library.theme.line, 0.35, 1)

	sidebar.popup_search = create("TextBox", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ClearTextOnFocus = false,
		Position = UDim2.fromOffset(6, 0),
		Size = UDim2.new(1, -12, 1, 0),
		Font = Enum.Font.GothamSemibold,
		PlaceholderText = "Search",
		PlaceholderColor3 = self.window.library.theme.text_soft,
		Text = "",
		TextColor3 = self.window.library.theme.text,
		TextSize = 11,
		TextXAlignment = Enum.TextXAlignment.Left,
	}, popup_search_shell)

	sidebar.popup_results = create("ScrollingFrame", {
		Active = true,
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		CanvasSize = UDim2.fromOffset(0, 0),
		Position = UDim2.fromOffset(8, 38),
		Size = UDim2.new(1, -16, 1, -46),
		ScrollBarImageColor3 = self.window.library.theme.line,
		ScrollBarImageTransparency = 0.2,
		ScrollBarThickness = 2,
	}, sidebar.popup)
	sidebar.popup_layout = create("UIListLayout", {
		SortOrder = Enum.SortOrder.LayoutOrder,
		Padding = UDim.new(0, 2),
	}, sidebar.popup_results)

	sidebar.popup_empty = create("TextLabel", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		BackgroundTransparency = 1,
		Position = UDim2.new(0.5, 0, 0.55, 0),
		Size = UDim2.new(1, -24, 0, 16),
		Font = Enum.Font.GothamMedium,
		Text = "nothing found",
		TextSize = 11,
		TextColor3 = self.window.library.theme.text_soft,
		Visible = false,
	}, sidebar.popup)

	sidebar.config_entry = refresh_search_entry({
		kind = "scope_sidebar",
		name = sidebar.name,
		flag = sidebar.flag,
		search_hidden = true,
		tab = self,
		tab_name = self.name,
		control = sidebar,
	})
	function sidebar.config_entry:GetConfigValue(use_defaults)
		return sidebar:GetConfigValue(use_defaults)
	end
	function sidebar.config_entry:ApplyConfigValue(value, fire_callback)
		sidebar:ApplyConfigValue(value, fire_callback)
	end
	insert(self.window.entries, sidebar.config_entry)

	connect(self.window.connections, sidebar.scope_layout:GetPropertyChangedSignal("AbsoluteContentSize"), function()
		sidebar.scope_results.CanvasSize = UDim2.fromOffset(0, sidebar.scope_layout.AbsoluteContentSize.Y)
	end)
	connect(self.window.connections, sidebar.popup_layout:GetPropertyChangedSignal("AbsoluteContentSize"), function()
		sidebar.popup_results.CanvasSize = UDim2.fromOffset(0, sidebar.popup_layout.AbsoluteContentSize.Y)
	end)
	connect(self.window.connections, sidebar.add_button.MouseEnter, function()
		tween(sidebar.add_button, 0.12, { TextColor3 = self.window.library.theme.text })
	end)
	connect(self.window.connections, sidebar.add_button.MouseLeave, function()
		tween(sidebar.add_button, 0.12, { TextColor3 = self.window.library.theme.text_soft })
	end)
	connect(self.window.connections, sidebar.add_button.MouseButton1Click, function()
		sidebar:SetPopupVisible(not sidebar.popup_open)
	end)
	connect(self.window.connections, sidebar.popup_overlay.MouseButton1Click, function()
		sidebar:SetPopupVisible(false)
	end)
	connect(self.window.connections, sidebar.popup_search:GetPropertyChangedSignal("Text"), function()
		sidebar:_refresh_add_popup_results()
	end)
	connect(self.window.connections, self.window.root:GetPropertyChangedSignal("AbsolutePosition"), function()
		sidebar:_refresh_popup_position()
	end)
	connect(self.window.connections, self.window.root:GetPropertyChangedSignal("AbsoluteSize"), function()
		sidebar:_refresh_popup_position()
	end)

	sidebar.scope_lookup[sidebar.catalog.global.key] = deep_copy(sidebar.catalog.global)
	sidebar.active_scope_key = sidebar.catalog.global.key
	sidebar:_rebuild_sidebar_rows()
	bump_zindex(sidebar.popup, 20)
	return sidebar
end

return Library
