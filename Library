local function ensure_folder(path)
	if type(path) ~= "string" or path == "" or not FileApi.makefolder then
		return false
	end

	if FileApi.isfolder then
		local ok, exists = pcall(FileApi.isfolder, path)
		if ok and exists then
			return true
		end
	end

	local created = pcall(FileApi.makefolder, path)
	if created then
		return true
	end

	if FileApi.isfolder then
		local ok, exists = pcall(FileApi.isfolder, path)
		return ok and exists
	end

	return false
end

local function ensure_storage_tree(storage_root, folders)
	ensure_folder("npdata")
	ensure_folder(storage_root)
	for _, folder in ipairs(folders or {}) do
		ensure_folder(storage_root .. "/" .. folder)
	end
end

local function serialize_enum_item(value)
	if typeof(value) == "EnumItem" then
		return tostring(value)
	end
	return nil
end

local function deserialize_enum_item(value)
	if typeof(value) == "EnumItem" then
		return value
	end

	if type(value) ~= "string" or not string.match(value, "^Enum%.") then
		return nil
	end

	local current = Enum
	local is_first = true
	for segment in string.gmatch(value, "[^%.]+") do
		if is_first then
			is_first = false
		else
			local next_value = current[segment]
			if next_value == nil then
				return nil
			end
			current = next_value
		end
	end

	return typeof(current) == "EnumItem" and current or nil
end

local function normalize_bind_mode(mode, fallback)
	local normalized = string.lower(tostring(mode or fallback or "toggle"))
	if normalized == "toggle" or normalized == "hold" or normalized == "always" then
		return normalized
	end
	return string.lower(tostring(fallback or "toggle"))
end

local function serialize_bind_list(binds)
	local result = {}
	for _, bind in ipairs(binds or {}) do
		local token = serialize_enum_item(bind and (bind.key or bind.Key))
		if token then
			insert(result, {
				key = token,
				mode = normalize_bind_mode(bind and (bind.mode or bind.Mode), "toggle"),
			})
		end
	end
	return result
end

local function deserialize_bind_list(binds)
	local result = {}
	if type(binds) ~= "table" then
		return result
	end

	for _, bind in ipairs(binds) do
		if type(bind) == "table" then
			local token = deserialize_enum_item(bind.key or bind.Key)
			if token then
				insert(result, {
					key = token,
					mode = normalize_bind_mode(bind.mode or bind.Mode, "toggle"),
				})
			end
		end
	end

	return result
end

local function serialize_color3(value)
	if typeof(value) == "Color3" then
		return value:ToHex()
	end
	return nil
end

local function deserialize_color3(value)
	if typeof(value) == "Color3" then
		return value
	end

	if type(value) ~= "string" then
		return nil
	end

	local text = trim_string(value)
	if text == "" then
		return nil
	end

	local hex_value = text:match("#(%x%x%x%x%x%x)")
	if not hex_value and text:match("^%x%x%x%x%x%x$") then
		hex_value = text
	end

	if not hex_value then
		return nil
	end

	local ok, parsed = pcall(Color3.fromHex, "#" .. string.upper(hex_value))
	return ok and parsed or nil
end

local function is_config_entry(entry)
	if type(entry) ~= "table" then
		return false
	end
	if type(entry.GetConfigValue) == "function" or type(entry.ApplyConfigValue) == "function" then
		return true
	end
	return entry.flag ~= nil and entry.skip_config ~= true
end

local function get_config_entry_value(entry, use_defaults)
	if not is_config_entry(entry) then
		return nil
	end

	if type(entry.GetConfigValue) == "function" then
		return entry:GetConfigValue(use_defaults)
	end

	if entry.kind == "toggle" and entry.control then
		local bind_info = entry.control:GetBind()
		local binds = entry.control.GetBinds and entry.control:GetBinds() or {}
		local source = {
			state = entry.control:Get(),
			mode = bind_info.mode,
			bind = bind_info.key,
			binds = binds,
		}

		if use_defaults then
			source = {
				state = entry.default_state == true,
				mode = entry.default_mode or "toggle",
				bind = entry.default_bind or "none",
				binds = deep_copy(entry.default_binds or {}),
			}
		end

		local payload = {
			state = source.state == true,
			mode = source.mode,
			bind = source.bind == "none" and "none" or serialize_enum_item(source.bind),
		}
		local serialized_binds = serialize_bind_list(source.binds)
		if #serialized_binds > 0 then
			payload.binds = serialized_binds
		end
		return payload
	end

	if entry.kind == "slider" and entry.control then
		if use_defaults then
			return entry.default_value
		end
		return entry.control:Get()
	end

	if entry.kind == "dropdown" and entry.control then
		if use_defaults then
			return deep_copy(entry.default_value)
		end
		return entry.control:Get()
	end

	if entry.kind == "colorpicker" and entry.control then
		if use_defaults then
			return {
				color = serialize_color3(entry.default_color),
				alpha = entry.default_alpha,
				transparency = entry.default_transparency,
			}
		end

		local current = entry.control:Get()
		return {
			color = serialize_color3(current.color),
			alpha = current.alpha,
			transparency = current.transparency,
		}
	end

	return nil
end

local function apply_config_entry_value(entry, value, fire_callback)
	if not is_config_entry(entry) then
		return
	end

	if type(entry.ApplyConfigValue) == "function" then
		entry:ApplyConfigValue(value, fire_callback)
		return
	end

	if entry.kind == "toggle" and entry.control then
		local control = entry.control
		local previous_mute = control._mute_callback
		if not fire_callback then
			control._mute_callback = true
		end

		local next_state = value
		local next_mode
		local next_bind
		local next_binds

		if type(value) == "table" then
			next_state = value.state
			if next_state == nil then
				next_state = value.active
			end

			next_mode = value.mode or value.Mode
			next_bind = deserialize_enum_item(value.bind or value.key or value.Bind)
			if value.binds ~= nil or value.Binds ~= nil then
				next_binds = deserialize_bind_list(value.binds or value.Binds)
			end
		end

		if next_binds ~= nil and control.SetBinds then
			control:SetBinds(next_binds)
		else
			if type(next_mode) == "string" and next_mode ~= "" then
				control:SetMode(string.lower(next_mode))
			end

			if next_bind then
				control:SetBind(next_bind)
			elseif type(value) == "table" and (value.bind == "none" or value.key == "none" or value.Bind == "none") and control.SetBinds then
				control:SetBinds({})
			end
		end

		control:Set(next_state == true)
		control._mute_callback = previous_mute
		return
	end

	if entry.kind == "slider" and entry.control then
		local control = entry.control
		local previous_mute = control._mute_callback
		if not fire_callback then
			control._mute_callback = true
		end

		local next_value = value
		if type(value) == "table" then
			next_value = value.value
			if next_value == nil then
				next_value = value.state
			end
		end

		local numeric = tonumber(next_value)
		if numeric ~= nil then
			control:Set(numeric)
		end

		control._mute_callback = previous_mute
		return
	end

	if entry.kind == "dropdown" and entry.control then
		local control = entry.control
		local previous_mute = control._mute_callback
		if not fire_callback then
			control._mute_callback = true
		end

		local next_value = value
		if type(value) == "table" then
			next_value = value.value
			if next_value == nil then
				next_value = value.selected
			end
			if next_value == nil then
				next_value = value.state
			end
			-- Multi dropdowns are saved as a plain list/map of selected options
			-- (see dropdown:Get()), not as a {value=...} wrapper — pass it through
			if next_value == nil and control.multi then
				next_value = value
			end
		end

		if next_value ~= nil then
			if control.multi and type(next_value) == "table" then
				control:Set(next_value)
			else
				control:Set(tostring(next_value))
			end
		end

		control._mute_callback = previous_mute
		return
	end

	if entry.kind == "colorpicker" and entry.control then
		local control = entry.control
		local previous_mute = control._mute_callback
		if not fire_callback then
			control._mute_callback = true
		end

		local next_color = value
		local next_alpha

		if type(value) == "table" then
			next_color = deserialize_color3(value.color or value.Color)
			next_alpha = value.alpha
			if type(next_alpha) ~= "number" then
				next_alpha = normalize_alpha(nil, value.transparency or value.Transparency, control:Get().alpha)
			end
		else
			next_color = deserialize_color3(value)
		end

		if next_color then
			control:SetColor(next_color, next_alpha, true)
		elseif type(next_alpha) == "number" then
			control:SetAlpha(next_alpha)
		end

		control._mute_callback = previous_mute
		return
	end
end

local function cfg_escape(value)
	return tostring(value or ""):gsub("\\", "\\\\"):gsub("\n", "\\n")
end

local function cfg_unescape(value)
	return tostring(value or ""):gsub("\\n", "\n"):gsub("\\\\", "\\")
end

local function cfg_parse_scalar(value)
	local trimmed = trim_string(cfg_unescape(value))
	local lowered = string.lower(trimmed)
	if lowered == "true" then
		return true
	end
	if lowered == "false" then
		return false
	end

	local numeric = tonumber(trimmed)
	if numeric ~= nil then
		return numeric
	end

	return trimmed
end

local function encode_cfg(payload)
	local lines = {
		"; cfg data",
		"[meta]",
		"format=cfg",
		"title=" .. cfg_escape(payload.meta and payload.meta.title or ""),
		"version=" .. cfg_escape(payload.meta and payload.meta.version or 1),
		"directory=" .. cfg_escape(payload.meta and payload.meta.directory or ""),
	}

	local settings = payload.settings or {}
	local flags = {}
	for flag in pairs(settings) do
		insert(flags, flag)
	end
	table.sort(flags, function(left, right)
		return string.lower(left) < string.lower(right)
	end)

	for _, flag in ipairs(flags) do
		local data = settings[flag]
		insert(lines, "")
		insert(lines, "[" .. cfg_escape(flag) .. "]")
		if type(data) == "table" then
			local keys = {}
			for key in pairs(data) do
				insert(keys, key)
			end
			table.sort(keys, function(left, right)
				return string.lower(left) < string.lower(right)
			end)

			for _, key in ipairs(keys) do
				local value = data[key]
				if value ~= nil then
					insert(lines, tostring(key) .. "=" .. cfg_escape(value))
				end
			end
		else
			insert(lines, "state=" .. cfg_escape(data))
		end
	end

	return concat(lines, "\n")
end

local function decode_cfg(text)
	local payload = {
		meta = {},
		settings = {},
	}

	local current_section = nil
	for raw_line in string.gmatch(tostring(text or ""), "[^\r\n]+") do
		local line = trim_string(raw_line)
		if line ~= "" and line:sub(1, 1) ~= ";" and line:sub(1, 1) ~= "#" then
			local section_name = line:match("^%[(.-)%]$")
			if section_name then
				current_section = cfg_unescape(section_name)
				if current_section ~= "meta" and payload.settings[current_section] == nil then
					payload.settings[current_section] = {}
				end
			else
				local key, value = line:match("^([^=]+)=(.*)$")
				if key then
					key = trim_string(key)
					local parsed_value = cfg_parse_scalar(value)
					if current_section == "meta" then
						payload.meta[key] = parsed_value
					elseif current_section then
						payload.settings[current_section][key] = parsed_value
					end
				end
			end
		end
	end

	return payload
end

