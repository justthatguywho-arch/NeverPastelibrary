	end)
	connect(self.window.connections, self.window.root:GetPropertyChangedSignal("AbsoluteSize"), function()
		if toggle.popup_open then
			refresh_popup_height()
		end
	end)

	toggle._mute_callback = options.FireOnInit == nil and true or not options.FireOnInit
	refresh_primary_bind()
	toggle:SetBinds(toggle.binds)
	toggle:SetMode(toggle.bind.mode)
	toggle:Set(state)
