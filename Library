function Section:AddSlider(options)
	options = normalize(options, "Name")
	local flag = options.Flag or options.Name or ("s_" .. tostring(random(1, 9999999)))
	local minimum = tonumber(options.Min or options.Minimum or 0) or 0
	local maximum = tonumber(options.Max or options.Maximum or 100) or 100
	if maximum < minimum then
		minimum, maximum = maximum, minimum
	end

	local step = tonumber(options.Step or options.Increment or options.Interval or options.Decimal or 1) or 1
	if step <= 0 then
		step = 1
	end

	local precision = infer_precision(step, options.Decimals or options.Precision)
	local suffix = tostring(options.Suffix or "")
	local row_height = options.Height or 17
	local slot_width = options.SlotWidth or 85
	local row, _, hitbox, label, slot, slot_stroke = self:_setting_row(row_height, slot_width)
	label.Text = options.Name or ""
	slot.BackgroundColor3 = self.library.theme.bg
	slot.Size = UDim2.fromOffset(slot_width, 11)
	slot.Position = UDim2.new(1, -3, 0.5, 0)
	round_ui(slot, 2)
	slot_stroke.Transparency = 1

	label.Size = UDim2.new(1, -(slot_width + 12), 1, 0)
	label.Font = Enum.Font.GothamSemibold
	label.TextSize = 13
	label.TextColor3 = self.library.theme.text
	label.TextTransparency = 0.2

	local fill = create("Frame", {
		Size = UDim2.fromScale(0, 1),
		BackgroundColor3 = self.library.theme.accent,
		BorderSizePixel = 0,
		ZIndex = 1,
	}, slot)
	round_ui(fill, 2)

	local value_label = create("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.fromScale(1, 1),
		Font = Enum.Font.GothamSemibold,
		Text = "",
		TextSize = 9,
		TextXAlignment = Enum.TextXAlignment.Center,
		TextYAlignment = Enum.TextYAlignment.Center,
		TextColor3 = self.library.theme.text,
		TextStrokeColor3 = Color3.new(0, 0, 0),
		TextStrokeTransparency = 0.85,
		ZIndex = 3,
	}, slot)

	local slider = {
		library = self.library,
		window = self.window,
		section = self,
		flag = flag,
		frame = row,
		hitbox = hitbox,
		label = label,
		value_label = value_label,
		min = minimum,
		max = maximum,
		step = step,
		precision = precision,
		suffix = suffix,
	}

	local default_value = quantize_number(options.Default ~= nil and options.Default or minimum, minimum, maximum, step, precision)
	local current = default_value
	local dragging = false
	self.library.flags[flag] = current

	local function progress_for(value)
		if maximum <= minimum then
			return 0
		end

		return clamp((value - minimum) / (maximum - minimum), 0, 1)
	end

	local function display_text(value)
		if type(options.Format) == "function" then
			local ok, formatted = pcall(options.Format, value)
			if ok and formatted ~= nil then
				return tostring(formatted)
			end
		end

		return format_number(value, precision) .. suffix
	end

	local function render(value)
		local progress = progress_for(value)
		fill.Size = UDim2.new(progress, 0, 1, 0)
		value_label.Text = display_text(value)
	end

	local function update_from_pointer()
		local point = picker_input_position()
		local progress = clamp((point.X - slot.AbsolutePosition.X) / max(slot.AbsoluteSize.X, 1), 0, 1)
		slider:Set(minimum + ((maximum - minimum) * progress))
	end

	function slider:Set(value)
		current = quantize_number(value, minimum, maximum, step, precision)
		self.library.flags[self.flag] = current
		render(current)
		if options.Callback and not self._mute_callback then
			options.Callback(current)
		end
		return current
	end

	function slider:Get()
		return current
	end

	function slider:SetText(value)
		self.label.Text = tostring(value or "")
		if self.search_entry then
			self.search_entry.name = tostring(value or "")
			refresh_search_entry(self.search_entry)
		end
	end

	function slider:SetVisible(value)
		self.frame.Visible = value == true
	end

	connect(self.window.connections, hitbox.MouseEnter, function()
		tween(label, 0.18, { TextTransparency = 0.05 })
		tween(value_label, 0.18, { TextStrokeTransparency = 0.75 })
		tween(slot, 0.18, { BackgroundColor3 = slider.library.theme.panel })
	end)

	connect(self.window.connections, hitbox.MouseLeave, function()
		if dragging then
			return
		end
		tween(label, 0.18, { TextTransparency = 0.2 })
		tween(value_label, 0.18, { TextStrokeTransparency = 0.85 })
		tween(slot, 0.18, { BackgroundColor3 = slider.library.theme.bg })
	end)

	connect(self.window.connections, hitbox.InputBegan, function(input)
		if input.UserInputType ~= Enum.UserInputType.MouseButton1 then
			return
		end

		dragging = true
		update_from_pointer()
		tween(label, 0.12, { TextTransparency = 0 })
		tween(slot, 0.12, { BackgroundColor3 = slider.library.theme.panel })
	end)

	insert(self.window._input_changed_hooks, function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			update_from_pointer()
		end
	end)

	insert(self.window._input_ended_hooks, function(input)
		if input.UserInputType ~= Enum.UserInputType.MouseButton1 then
			return
		end

		dragging = false
		if point_inside(hitbox, picker_input_position()) then
			tween(label, 0.18, { TextTransparency = 0.05 })
			tween(slot, 0.18, { BackgroundColor3 = slider.library.theme.panel })
		else
			tween(label, 0.18, { TextTransparency = 0.2 })
			tween(slot, 0.18, { BackgroundColor3 = slider.library.theme.bg })
		end
	end)

	slider._mute_callback = options.FireOnInit == nil and true or not options.FireOnInit
	slider:Set(default_value)
	slider._mute_callback = nil
	slider.search_entry = refresh_search_entry({
		kind = "slider",
		name = options.Name or "",
		flag = flag,
		skip_config = options.SkipConfig == true,
		default_value = default_value,
		tab = self.tab,
		tab_name = self.tab.name,
		section_name = self.name,
		control = slider,
	})
	insert(self.window.entries, slider.search_entry)
	return slider
end

function Section:AddDropdown(options)
	options = normalize(options, "Name")
	local flag = options.Flag or options.Name or ("d_" .. tostring(random(1, 9999999)))
	local values = normalize_dropdown_values(options.Values or options.Options or options.List or options.Items)
	local placeholder = tostring(options.Placeholder or "None")
	local row_height = options.Height or 17
	local slot_width = options.SlotWidth or 75
	local is_multi = options.Multi == true
	local row, _, hitbox, label, slot, slot_stroke = self:_setting_row(row_height, slot_width)
	label.Text = options.Name or ""

	slot.BackgroundColor3 = self.library.theme.bg
	slot.Size = UDim2.fromOffset(slot_width, 15)
	slot.Position = UDim2.new(1, -3, 0.5, 0)
	slot_stroke.Transparency = 1

	label.Size = UDim2.new(1, -(slot_width + 12), 1, 0)
	label.Font = Enum.Font.GothamSemibold
	label.TextSize = 13
	label.TextColor3 = self.library.theme.text
	label.TextTransparency = 0.2

	local button = create("TextButton", {
		Size = UDim2.fromScale(1, 1),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Text = "",
		AutoButtonColor = false,
	}, slot)

	local selected_label = create("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(3, 0),
		Size = UDim2.new(1, -18, 0.8, 0),
		Font = Enum.Font.GothamSemibold,
		Text = "",
		TextColor3 = self.library.theme.text,
		TextSize = 10,
		TextTransparency = 0.5,
		TextWrapped = true,
		TextTruncate = Enum.TextTruncate.SplitWord,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Top,
	}, button)

	local arrow = create("TextLabel", {
		AnchorPoint = Vector2.new(1, 0),
		BackgroundTransparency = 1,
		Position = UDim2.new(1, 0, 0, 0),
		Size = UDim2.fromOffset(15, 15),
		Text = "▼",
		TextSize = 8,
		TextColor3 = self.library.theme.text,
		Font = Enum.Font.GothamBold,
		TextXAlignment = Enum.TextXAlignment.Center,
		TextYAlignment = Enum.TextYAlignment.Center,
		BorderSizePixel = 0,
	}, button)

	local popup = nil
	local popup_stroke = nil
	local popup_list = nil
	local popup_layout = nil
	local popup_overlay = nil

	local dropdown = {
		library = self.library,
		window = self.window,
		section = self,
		flag = flag,
		multi = is_multi,
		frame = row,
		hitbox = hitbox,
		label = label,
		slot = slot,
		button = button,
		selected_label = selected_label,
		arrow = arrow,
		popup = nil,
		popup_stroke = nil,
		values = {},
		option_buttons = {},
		popup_open = false,
	}

	local current = is_multi and {} or nil
	local popup_target_height = 0
	local popup_last_height = 0

	local function get_selection_text()
		if dropdown.multi then
			local selected_values = dropdown_selection_list(dropdown.values, current)
			return #selected_values > 0 and concat(selected_values, " , ") or placeholder, #selected_values > 0
		end

		return (current and tostring(current) or placeholder), current ~= nil
	end

	local function refresh_button_state()
		local text, has_value = get_selection_text()
		selected_label.Text = text
		selected_label.TextColor3 = has_value and dropdown.library.theme.text or dropdown.library.theme.text
		selected_label.TextTransparency = has_value and 0.5 or 0.75
	end

	local function refresh_option_styles()
		for value, entry in pairs(dropdown.option_buttons) do
			local active = dropdown.multi and current[value] == true or value == current
			entry.button.TextColor3 = active and dropdown.library.theme.accent or dropdown.library.theme.text
			entry.button.TextTransparency = active and 0 or 0.15
		end
	end

	local function create_popup()
		if popup then return end
		popup_overlay = create("TextButton", {
			Position = UDim2.fromOffset(-2000, -2000),
			Size = UDim2.fromOffset(6000, 6000),
			BackgroundTransparency = 1,
			Text = "",
			ZIndex = 49,
			Active = true,
		}, self.window.popup_container)
		connect(self.window.connections, popup_overlay.MouseButton1Click, function()
			dropdown:SetPopupVisible(false)
		end)
		popup = create("Frame", {
			BackgroundColor3 = dropdown.library.theme.bg,
			BorderSizePixel = 0,
			ClipsDescendants = true,
			Active = true,
			Position = UDim2.fromOffset(0, 0),
			Size = UDim2.fromOffset(175, 0),
			ZIndex = 50,
		}, self.window.popup_container)
		round_ui(popup, 2)
		popup_stroke = stroke(popup, dropdown.library.theme.line, 1, 1)
		popup_list = create("Frame", {
			AnchorPoint = Vector2.new(0.5, 0.5),
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			ClipsDescendants = true,
			Position = UDim2.fromScale(0.5, 0.5),
			Size = UDim2.new(1, -5, 1, -5),
		}, popup)
		popup_layout = create("UIListLayout", {
			SortOrder = Enum.SortOrder.LayoutOrder,
			Padding = UDim.new(0, 5),
		}, popup_list)
		dropdown.popup = popup
		dropdown.popup_stroke = popup_stroke
	end

	local function destroy_popup()
		if popup_overlay then
			popup_overlay:Destroy()
		end
		popup_overlay = nil
		if popup then
			popup:Destroy()
		end
		popup = nil
		popup_stroke = nil
		popup_list = nil
		popup_layout = nil
		dropdown.popup = nil
		dropdown.popup_stroke = nil
		popup_last_height = 0
		table.clear(dropdown.option_buttons)
	end

	local function update_popup_geometry(animate_size)
		if not popup_layout or not popup then return end
		local layout_h = popup_layout.AbsoluteContentSize.Y
		if layout_h < 1 then
			local count = #dropdown.values
			local spacing = popup_layout.Padding.Offset
			layout_h = count * 10 + math.max(0, count - 1) * spacing
		end
		local base_height = layout_h + 10
		popup_target_height = clamp(base_height, 20, 200)

		local root_offset = self.window.root.AbsolutePosition
		local slot_pos = slot.AbsolutePosition
		popup.Position = UDim2.fromOffset(slot_pos.X - root_offset.X, slot_pos.Y - root_offset.Y + slot.AbsoluteSize.Y + 4)

		if dropdown.popup_open and popup_target_height ~= popup_last_height then
			popup_last_height = popup_target_height
			if animate_size then
				tween(popup, 0.35, { Size = UDim2.fromOffset(175, popup_target_height) })
			else
				popup.Size = UDim2.fromOffset(175, popup_target_height)
			end
		end
	end

	local function rebuild_options()
		if not popup_list then return end
		for _, child in ipairs(popup_list:GetChildren()) do
			if child:IsA("TextButton") then
				child:Destroy()
			end
		end
		table.clear(dropdown.option_buttons)

		for _, value in ipairs(dropdown.values) do
			local option_button = create("TextButton", {
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, 10),
				Font = Enum.Font.GothamSemibold,
				Text = tostring(value),
				TextSize = 12,
				TextXAlignment = Enum.TextXAlignment.Left,
				TextColor3 = dropdown.library.theme.text,
			}, popup_list)

			dropdown.option_buttons[value] = {
				button = option_button,
			}

			connect(self.window.connections, option_button.MouseButton1Click, function()
				if dropdown.multi then
					dropdown:ToggleValue(value)
				else
					dropdown:Set(value)
				end
			end)
		end

		refresh_option_styles()
		update_popup_geometry()
	end

	local function toggle_popup_visuals(open)
		if open then
			create_popup()
			rebuild_options()
			update_popup_geometry(false)
			if popup then
				popup.Size = UDim2.fromOffset(175, 0)
			end
			tween(popup, 0.35, { Size = UDim2.fromOffset(175, popup_target_height) })
			tween(popup_stroke, 0.35, { Transparency = 0 })
			task.defer(function()
				if dropdown.popup_open then
					update_popup_geometry(true)
				end
			end)
			tween(arrow, 0.35, { Rotation = -180, TextColor3 = dropdown.library.theme.accent })
		else
			if popup then
				tween(popup, 0.35, { Size = UDim2.fromOffset(175, 0) })
			end
			if popup_stroke then
				tween(popup_stroke, 0.35, { Transparency = 1 })
			end
			tween(arrow, 0.35, { Rotation = 0, TextColor3 = dropdown.library.theme.text })
			task.delay(0.35, function()
				if not dropdown.popup_open then
					destroy_popup()
				end
			end)
		end
	end

	function dropdown:SetPopupVisible(value)
		self.popup_open = value == true
		if self.popup_open then
			if self.window.current_popup and self.window.current_popup ~= self then
				self.window.current_popup:SetPopupVisible(false)
			end
			self.window.current_popup = self
		elseif self.window.current_popup == self then
			self.window.current_popup = nil
		end

		refresh_button_state()
		toggle_popup_visuals(self.popup_open)
	end

	function dropdown:Set(value)
		if self.multi then
			current = normalize_dropdown_selection(self.values, value, true)
			local payload = dropdown_selection_list(self.values, current)
			self.library.flags[self.flag] = shallow_copy(payload)
			refresh_button_state()
			refresh_option_styles()
			if options.Callback and not self._mute_callback then
				options.Callback(shallow_copy(payload), shallow_copy(current))
			end
			return shallow_copy(payload)
		end

		local next_value = value ~= nil and tostring(value) or nil
		if next_value ~= nil and next_value ~= "" and not list_contains(self.values, next_value) then
			return false
		end

		current = next_value
		self.library.flags[self.flag] = current
		refresh_button_state()
		refresh_option_styles()
		if options.Callback and not self._mute_callback then
			options.Callback(current)
		end
		return true
	end

	function dropdown:Get()
		if self.multi then
			return dropdown_selection_list(self.values, current)
		end
		return current
	end

	function dropdown:SetText(value)
		self.label.Text = tostring(value or "")
		if self.search_entry then
			self.search_entry.name = tostring(value or "")
			refresh_search_entry(self.search_entry)
		end
	end

	function dropdown:IsSelected(value)
		local token = tostring(value)
		if self.multi then
			return current[token] == true
		end
		return current == token
	end

	function dropdown:ToggleValue(value)
		if not self.multi then
			return self:Set(value)
		end

		local token = tostring(value)
		if not list_contains(self.values, token) then
			return false
		end

		local next_state = shallow_copy(current)
		next_state[token] = not next_state[token] or nil
		return self:Set(next_state)
	end

	function dropdown:SetOptions(new_values, keep_current)
		self.values = normalize_dropdown_values(new_values)
		rebuild_options()

		if self.multi then
			if keep_current then
				self:Set(current)
				return
			end
			self:Set(normalize_dropdown_selection(self.values, options.Default, true))
			return
		end

		if keep_current and current and list_contains(self.values, current) then
			self:Set(current)
			return
		end

		local requested_default = options.Default ~= nil and tostring(options.Default) or nil
		if requested_default and list_contains(self.values, requested_default) then
			self:Set(requested_default)
		else
			self:Set(self.values[1])
		end
	end

	function dropdown:SetVisible(value)
		self.frame.Visible = value == true
		if not value and self.popup_open then
			self:SetPopupVisible(false)
		end
	end

	dropdown.SetData = dropdown.SetOptions

	insert(self.window._heartbeat_hooks, function()
		if dropdown.popup_open and popup and popup.Parent and slot.Parent then
			update_popup_geometry()
		end
	end)

	connect(self.window.connections, hitbox.MouseEnter, function()
		tween(label, 0.45, { TextTransparency = 0.05 })
		tween(slot, 0.18, { BackgroundColor3 = dropdown.library.theme.panel })
		local _, has_value = get_selection_text()
		tween(selected_label, 0.18, { TextTransparency = has_value and 0.35 or 0.55 })
	end)

	connect(self.window.connections, hitbox.MouseLeave, function()
		if dropdown.popup_open then
			return
		end
		tween(label, 0.45, { TextTransparency = 0.2 })
		tween(slot, 0.18, { BackgroundColor3 = dropdown.library.theme.bg })
		local _, has_value = get_selection_text()
		tween(selected_label, 0.18, { TextTransparency = has_value and 0.5 or 0.75 })
	end)

	connect(self.window.connections, button.MouseButton1Click, function()
		dropdown:SetPopupVisible(not dropdown.popup_open)
	end)

	connect(self.window.connections, hitbox.MouseButton1Click, function()
		dropdown:SetPopupVisible(not dropdown.popup_open)
	end)


	if #values == 0 and options.Default ~= nil then
		if is_multi and type(options.Default) == "table" then
			if #options.Default > 0 then
				for _, value in ipairs(options.Default) do
					insert(values, tostring(value))
				end
			else
				for key, value in pairs(options.Default) do
					if value == true then
						insert(values, tostring(key))
					elseif value ~= nil then
						insert(values, tostring(value))
					end
				end
			end
		else
			insert(values, tostring(options.Default))
		end
	end

	dropdown._mute_callback = options.FireOnInit == nil and true or not options.FireOnInit
	dropdown:SetOptions(values, false)
	if options.Default ~= nil then
		dropdown:Set(options.Default)
	end
	dropdown._mute_callback = nil
	refresh_button_state()

	dropdown.search_entry = refresh_search_entry({
		kind = "dropdown",
