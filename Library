			self.window.current_popup = nil
		end
		refresh_popup_height()
	end

	function picker:SetColor(value, alpha_value, preserve_rainbow, preserve_hsv)
		local next_alpha = picker.alpha
		if type(alpha_value) == "number" then
			next_alpha = clamp(alpha_value, 0, 1)
		end
		picker.color = value
		picker.alpha = next_alpha
		if not preserve_hsv then
			local next_hue, next_sat, next_val = value:ToHSV()
			if next_sat > 0 and next_val > 0 then
				hue = next_hue
			end
			sat, val = next_sat, next_val
		end
		refresh_picker()
		sync_flags()
		if options.Callback and not self._mute_callback then
			options.Callback(picker.color, alpha_to_transparency(picker.alpha), picker.rainbow)
		end
	end

	function picker:SetAlpha(value)
		self:SetColor(self.color, value, true, true)
	end

	function picker:SetRainbow(value)
		picker.rainbow = value == true
		refresh_picker()
		sync_flags()
	end

	function picker:Get()
		return {
			color = picker.color,
			alpha = picker.alpha,
			transparency = alpha_to_transparency(picker.alpha),
			rainbow = false,
		}
	end

	function picker:Set(value)
		if type(value) ~= "table" then
			return
		end
		local next_color = deserialize_color3(value.color or value.Color)
		local next_alpha = value.alpha
		if type(next_alpha) ~= "number" then
			next_alpha = normalize_alpha(nil, value.transparency or value.Transparency, picker.alpha)
		end
		if next_color then
			self:SetColor(next_color, next_alpha, true)
		elseif type(next_alpha) == "number" then
			self:SetAlpha(next_alpha)
		end
	end

	function picker:SetText(value)
		if self.label then
			self.label.Text = tostring(value or "")
		end
		if self.search_entry then
			self.search_entry.name = tostring(value or "")
			refresh_search_entry(self.search_entry)
		end
	end

	function picker:SetVisible(value)
		self.frame.Visible = value == true
		if self.inline_target and self.inline_target.refresh_color_layout then
			self.inline_target:refresh_color_layout()
		end
		if not value and self.popup_open then
			self:SetPopupVisible(false)
		end
	end

	local function set_sv(point)
		sat = clamp((point.X - sv_picker.AbsolutePosition.X) / max(sv_picker.AbsoluteSize.X, 1), 0, 1)
		val = 1 - clamp((point.Y - sv_picker.AbsolutePosition.Y) / max(sv_picker.AbsoluteSize.Y, 1), 0, 1)
		picker:SetColor(hsv(hue, sat, val), picker.alpha, true, true)
	end

	local function set_hue(point)
		hue = clamp((point.Y - hue_picker.AbsolutePosition.Y) / max(hue_picker.AbsoluteSize.Y, 1), 0, 1)
		picker:SetColor(hsv(hue, sat, val), picker.alpha, true, true)
	end

	local function set_alpha(point)
		local value = clamp((point.X - alpha_row.AbsolutePosition.X) / max(alpha_row.AbsoluteSize.X, 1), 0, 1)
		picker:SetAlpha(value)
	end

	local function set_picker_from_input(mode, input)
		local point = vec2(input.Position.X, input.Position.Y)
		if mode == "sv" then
			set_sv(point)
		elseif mode == "hue" then
			set_hue(point)
		elseif mode == "alpha" then
			set_alpha(point)
		end
	end

	local function begin_picker_drag(target, mode)
		connect(self.window.connections, target.InputBegan, function(input)
			if input.UserInputType ~= Enum.UserInputType.MouseButton1 then
				return
			end
			color_dragging = mode
			set_picker_from_input(mode, input)
		end)
	end

	if picker.inline then
		connect(self.window.connections, hitbox.MouseEnter, function()
			tween(hitbox, 0.18, { BackgroundColor3 = picker.library.theme.panel })
			if picker.swatch_stroke then
				tween(picker.swatch_stroke, 0.18, { Transparency = 0.05 })
			end
		end)

		connect(self.window.connections, hitbox.MouseLeave, function()
			if picker.popup_open then
				return
			end
			tween(hitbox, 0.18, { BackgroundColor3 = picker.library.theme.panel_soft })
			if picker.swatch_stroke then
				tween(picker.swatch_stroke, 0.18, { Transparency = 0.2 })
			end
		end)
	else
		connect(self.window.connections, hitbox.MouseEnter, function()
			tween(label, 0.18, { TextTransparency = 0.05 })
			tween(slot, 0.18, { BackgroundColor3 = picker.library.theme.panel })
		end)

		connect(self.window.connections, hitbox.MouseLeave, function()
			if picker.popup_open then
				return
			end
			tween(label, 0.18, { TextTransparency = 0.2 })
			tween(slot, 0.18, { BackgroundColor3 = picker.library.theme.bg })
		end)
	end

	connect(self.window.connections, hitbox.MouseButton1Click, function()
		picker:SetPopupVisible(not picker.popup_open)
	end)

	connect(self.window.connections, popup_overlay.MouseButton1Click, function()
		picker:SetPopupVisible(false)
	end)

	connect(self.window.connections, copy_btn.MouseButton1Click, function()
		local value = tostring(hex_label.Text or ""):upper()
		picker.library.clipboard_color_text = value
		if ClipboardApi.set then
			pcall(ClipboardApi.set, value)
		end
	end)

	connect(self.window.connections, paste_btn.MouseButton1Click, function()
		local value = picker.library.clipboard_color_text
		if ClipboardApi.get then
			local ok, clipboard_value = pcall(ClipboardApi.get)
			if ok and type(clipboard_value) == "string" and trim_string(clipboard_value) ~= "" then
				value = clipboard_value
			end
		end

		local parsed = deserialize_color3(value)
		if parsed then
			picker:SetColor(parsed, picker.alpha, true)
		end
	end)

	begin_picker_drag(sv_picker, "sv")
	begin_picker_drag(hue_picker, "hue")
	begin_picker_drag(alpha_row, "alpha")

	insert(self.window._input_changed_hooks, function(input)
		if input.UserInputType ~= Enum.UserInputType.MouseMovement then
			return
		end
		if color_dragging == "sv" or color_dragging == "hue" or color_dragging == "alpha" then
			set_picker_from_input(color_dragging, input)
		end
	end)

	insert(self.window._input_ended_hooks, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			color_dragging = nil
		end
	end)

	connect(self.window.connections, popup_layout:GetPropertyChangedSignal("AbsoluteContentSize"), refresh_popup_height)
	connect(self.window.connections, self.window.root:GetPropertyChangedSignal("AbsolutePosition"), function()
		if picker.popup_open then
			refresh_popup_position()
		end
	end)
	connect(self.window.connections, self.window.root:GetPropertyChangedSignal("AbsoluteSize"), function()
		if picker.popup_open then
			refresh_popup_height()
		end
	end)

	picker._mute_callback = options.FireOnInit == nil and true or not options.FireOnInit
	picker:SetColor(default_color, default_alpha, true)
	refresh_picker()
	refresh_popup_height()
	picker._mute_callback = nil
	picker.search_entry = refresh_search_entry({
		kind = "colorpicker",
		name = options.Name or "",
		flag = flag,
		skip_config = options.SkipConfig == true,
		default_color = default_color,
		default_alpha = default_alpha,
		default_transparency = alpha_to_transparency(default_alpha),
		tab = self.tab,
		tab_name = self.tab.name,
		section_name = self.name,
		control = picker,
	})
	insert(self.window.entries, picker.search_entry)
	if inline_target and inline_target.refresh_color_layout then
		inline_target:refresh_color_layout()
	end
	bump_zindex(popup, 20)
	return picker
end

local function scope_get_value(entry, use_defaults)
	local saved = entry.skip_config
	entry.skip_config = nil
	local result = get_config_entry_value(entry, use_defaults)
	entry.skip_config = saved
	return result
end

local function scope_apply_value(entry, value, fire_callback)
	local saved = entry.skip_config
	entry.skip_config = nil
	apply_config_entry_value(entry, value, fire_callback)
	entry.skip_config = saved
end

local function create_scoped_control_wrapper(raw_control)
	return setmetatable({
		__raw_control = raw_control,
	}, {
		__index = function(_, key)
			return raw_control[key]
		end,
	})
end

local function create_scoped_section_wrapper(manager, raw_section)
	return setmetatable({
		manager = manager,
		section = raw_section,
		window = raw_section.window,
		library = raw_section.library,
		tab = raw_section.tab,
		name = raw_section.name,
	}, {
		__index = function(self, key)
			return ScopedSection[key] or raw_section[key]
		end,
	})
end

function ScopeSidebar:_coerce_scope(scope_or_kind, id, name, category_id)
	if type(scope_or_kind) == "table" then
		local source = scope_or_kind
		local normalized = build_scope_definition(
			source.kind or source.Kind,
			source.id or source.Id or source.key or source.Key or source.value or source.Value or id,
			source.name or source.Name or source.label or source.Label or name,
			source.category_id or source.CategoryId or source.category or source.Category or category_id,
			source.order or source.Order
		)
		if normalized then
			return normalized
		end
	end

	local normalized_kind = normalize_scope_kind(scope_or_kind)
	if normalized_kind then
		if normalized_kind == "global" then
			return deep_copy(self.catalog.global)
		end
		return build_scope_definition(normalized_kind, id, name or id, category_id)
	end

	if type(scope_or_kind) == "string" then
		local key_text = trim_string(scope_or_kind)
		local existing = self.scope_lookup[key_text] or self.catalog.by_key[key_text]
		if existing then
			return deep_copy(existing)
		end

		local token = normalize_scope_id(scope_or_kind)
		if not token then
			return nil
		end

		local weapon = self.catalog.weapon_lookup[make_scope_key("weapon", token)]
		if weapon then
			return deep_copy(weapon)
		end

		local category = self.catalog.category_lookup[make_scope_key("category", token)]
		if category then
			return deep_copy(category)
		end

		if token == "global" then
			return deep_copy(self.catalog.global)
		end
	end

	return nil
end

function ScopeSidebar:_get_sorted_scopes()
	local ordered = {}
	for _, scope in pairs(self.scope_lookup) do
		insert(ordered, scope)
	end

	table.sort(ordered, function(left, right)
		local left_rank = scope_kind_rank(left.kind)
		local right_rank = scope_kind_rank(right.kind)
		if left_rank ~= right_rank then
			return left_rank < right_rank
		end
		if left.order ~= right.order then
			return left.order < right.order
		end
		return string.lower(left.name) < string.lower(right.name)
	end)

	return ordered
end

function ScopeSidebar:_ensure_scope_values(scope_key)
	if type(self.scope_values[scope_key]) ~= "table" then
		self.scope_values[scope_key] = {}
	end
	return self.scope_values[scope_key]
end

function ScopeSidebar:_rebuild_sidebar_rows()
	for _, child in ipairs(self.scope_results:GetChildren()) do
		if child:IsA("GuiObject") then
			child:Destroy()
		end
	end

	local previous_kind = nil
	for _, scope in ipairs(self:_get_sorted_scopes()) do
		if previous_kind and previous_kind ~= scope.kind then
			local divider_row = create("Frame", {
				Size = UDim2.new(1, 0, 0, 12),
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				LayoutOrder = scope_kind_rank(scope.kind) * 1000 - 1,
			}, self.scope_results)

			create("Frame", {
				Position = UDim2.fromOffset(10, 5),
				Size = UDim2.new(1, -20, 0, 1),
				BackgroundColor3 = self.library.theme.line,
				BorderSizePixel = 0,
			}, divider_row)
		end
		previous_kind = scope.kind

		local row = create("TextButton", {
			Size = UDim2.new(1, 0, 0, 24),
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Text = "",
			AutoButtonColor = false,
			LayoutOrder = scope_kind_rank(scope.kind) * 1000 + scope.order,
		}, self.scope_results)

		local accent = create("Frame", {
			AnchorPoint = Vector2.new(0, 0.5),
			Position = UDim2.new(0, 0, 0.5, 0),
			Size = UDim2.new(0, 3, 1, -6),
			BackgroundColor3 = self.library.theme.accent,
			BorderSizePixel = 0,
			Visible = scope.key == self.active_scope_key,
		}, row)
		round_ui(accent, 1)

		local is_global = scope.kind == "global"

		local title = create("TextLabel", {
			BackgroundTransparency = 1,
			Position = UDim2.fromOffset(12, 0),
			Size = UDim2.new(1, is_global and -14 or -26, 1, 0),
			Font = Enum.Font.GothamSemibold,
			Text = scope.name,
			TextSize = 12,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextColor3 = scope.key == self.active_scope_key and self.library.theme.text or self.library.theme.text_soft,
		}, row)

		local delete_btn
		if not is_global then
			delete_btn = create("ImageButton", {
				AnchorPoint = Vector2.new(1, 0.5),
				Position = UDim2.new(1, -4, 0.5, 0),
				Size = UDim2.fromOffset(12, 12),
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Image = _icons.delete,
				ImageColor3 = self.library.theme.text_soft,
				ImageTransparency = 0.5,
				AutoButtonColor = false,
			}, row)

			connect(self.window.connections, delete_btn.MouseEnter, function()
				tween(delete_btn, 0.12, { ImageColor3 = self.library.theme.accent, ImageTransparency = 0 })
			end)
			connect(self.window.connections, delete_btn.MouseLeave, function()
				tween(delete_btn, 0.12, { ImageColor3 = self.library.theme.text_soft, ImageTransparency = 0.5 })
			end)
			connect(self.window.connections, delete_btn.MouseButton1Click, function()
				self:RemoveScope(scope.key)
			end)
		end

		connect(self.window.connections, row.MouseEnter, function()
			if scope.key ~= self.active_scope_key then
				tween(title, 0.12, { TextColor3 = self.library.theme.text })
			end
		end)
		connect(self.window.connections, row.MouseLeave, function()
			if scope.key ~= self.active_scope_key then
				tween(title, 0.12, { TextColor3 = self.library.theme.text_soft })
			end
		end)
		connect(self.window.connections, row.MouseButton1Click, function()
			self:SelectScope(scope.key)
		end)
	end
end

function ScopeSidebar:_refresh_add_popup_results()
	for _, child in ipairs(self.popup_results:GetChildren()) do
		if child:IsA("GuiObject") then
			child:Destroy()
		end
	end

	local filter = string.lower(trim_string(self.popup_search.Text or ""))
	local items = {}

	if not self.scope_lookup[self.catalog.global.key] then
		insert(items, self.catalog.global)
	end

	for _, scope in ipairs(self.catalog.categories) do
		if not self.scope_lookup[scope.key] then
			insert(items, scope)
		end
	end

	for _, scope in ipairs(self.catalog.weapons) do
		if not self.scope_lookup[scope.key] then
			insert(items, scope)
		end
	end

	local count = 0
	for _, scope in ipairs(items) do
		local haystack = string.lower(concat({
			scope.name,
			scope.id,
			scope.kind,
		}, " "))
		if filter == "" or string.find(haystack, filter, 1, true) then
			count = count + 1
			local row = create("TextButton", {
				Size = UDim2.new(1, 0, 0, 20),
				BackgroundColor3 = self.library.theme.panel_soft,
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Text = "",
				AutoButtonColor = false,
			}, self.popup_results)

			local title = create("TextLabel", {
				BackgroundTransparency = 1,
				Position = UDim2.fromOffset(8, 0),
				Size = UDim2.new(1, -16, 1, 0),
				Font = Enum.Font.GothamSemibold,
				Text = scope.name,
				TextSize = 11,
				TextXAlignment = Enum.TextXAlignment.Left,
				TextColor3 = self.library.theme.text_soft,
			}, row)

			connect(self.window.connections, row.MouseEnter, function()
				tween(title, 0.12, { TextColor3 = self.library.theme.text })
			end)
			connect(self.window.connections, row.MouseLeave, function()
				tween(title, 0.12, { TextColor3 = self.library.theme.text_soft })
			end)
			connect(self.window.connections, row.MouseButton1Click, function()
				local added = self:AddScope(scope, true)
				if added then
					self:SetPopupVisible(false)
				end
			end)
		end
	end

	self.popup_empty.Visible = count == 0
	self.popup_results.CanvasSize = UDim2.fromOffset(0, self.popup_layout.AbsoluteContentSize.Y)
end

function ScopeSidebar:_refresh_popup_position()
	if not self.popup_open then
		return
	end

	local popup_height = self.popup.AbsoluteSize.Y
	if popup_height <= 0 then
		popup_height = self.popup.Size.Y.Offset
	end

	local root_position = self.window.root.AbsolutePosition
	local root_size = self.window.root.AbsoluteSize

	local footer_height = self.window.footer and self.window.footer.AbsoluteSize.Y or 25
	local header_height = self.window.header and self.window.header.AbsoluteSize.Y or 40

	local max_bottom = root_size.Y - footer_height - 4

	self.popup.AnchorPoint = Vector2.new(0, 1)
	local x = 6
	local y = clamp(max_bottom, popup_height + header_height + 4, max(popup_height, root_size.Y))
	self.popup.Position = UDim2.fromOffset(x, y)
end

function ScopeSidebar:SetPopupVisible(value)
	self.popup_open = value == true
	self.popup_overlay.Visible = self.popup_open
	self.popup.Visible = self.popup_open

	if self.popup_open then
		if self.window.current_popup and self.window.current_popup ~= self then
			self.window.current_popup:SetPopupVisible(false)
		end
		self.window.current_popup = self
		self:_refresh_add_popup_results()
		self:_refresh_popup_position()
	else
		if self.window.current_popup == self then
			self.window.current_popup = nil
		end
	end
end

function ScopeSidebar:AddScope(scope_or_kind, select_after, id, name, category_id)
	if type(select_after) ~= "boolean" then
		category_id = name
		name = id
		id = select_after
		select_after = true
	end

	local scope = self:_coerce_scope(scope_or_kind, id, name, category_id)
	if not scope then
		return nil
	end

	if scope.kind == "global" then
		scope = deep_copy(self.catalog.global)
	end

	local existing = self.scope_lookup[scope.key]
	if existing then
		if select_after ~= false then
			self:SelectScope(existing.key)
		end
		return existing
	end

	self.scope_lookup[scope.key] = scope
	self:_rebuild_sidebar_rows()

	if select_after ~= false then
		self:SelectScope(scope.key)
	end

	return scope
end

function ScopeSidebar:RemoveScope(scope_ref)
	local scope = self:_coerce_scope(scope_ref)
	if not scope then
		return false
	end

	if scope.kind == "global" then
		return false
	end

	if not self.scope_lookup[scope.key] then
		return false
	end

	self:_snapshot_controls()

	self.scope_lookup[scope.key] = nil
	self.scope_values[scope.key] = nil

	if self.active_scope_key == scope.key then
		self.active_scope_key = self.catalog.global.key
		if not self.scope_lookup[self.catalog.global.key] then
			self.scope_lookup[self.catalog.global.key] = deep_copy(self.catalog.global)
		end
	end

	self:_rebuild_sidebar_rows()
	self:_load_controls(false)
	return true
end

function ScopeSidebar:GetScope(scope_ref)
	local scope = self:_coerce_scope(scope_ref)
	return scope and self.scope_lookup[scope.key] or nil
end

function ScopeSidebar:GetCurrentScope()
	return self.scope_lookup[self.active_scope_key] or self.catalog.global
end

function ScopeSidebar:_get_chain(context)
	local weapon_id
	local category_id

	if context == nil then
		local active = self:GetCurrentScope()
		if active.kind == "weapon" then
			weapon_id = active.id
			category_id = active.category_id
		elseif active.kind == "category" then
			category_id = active.id
		end
	elseif type(context) == "table" then
		if context.kind == "weapon" or context.Kind == "weapon" then
			weapon_id = normalize_scope_id(context.id or context.Id)
			category_id = normalize_scope_id(context.category_id or context.CategoryId or context.category or context.Category)
		elseif context.kind == "category" or context.Kind == "category" then
			category_id = normalize_scope_id(context.id or context.Id)
		elseif context.kind == "global" or context.Kind == "global" then
			weapon_id = nil
			category_id = nil
		else
			weapon_id = normalize_scope_id(context.weapon or context.Weapon or context.weapon_id or context.WeaponId)
			category_id = normalize_scope_id(context.category or context.Category or context.category_id or context.CategoryId)
		end
	elseif type(context) == "string" then
		local existing = self:_coerce_scope(context)
		if existing then
			if existing.kind == "weapon" then
				weapon_id = existing.id
				category_id = existing.category_id
			elseif existing.kind == "category" then
				category_id = existing.id
			end
		else
			local token = normalize_scope_id(context)
			if token then
				if self.catalog.weapon_lookup[make_scope_key("weapon", token)] then
					weapon_id = token
				elseif self.catalog.category_lookup[make_scope_key("category", token)] then
					category_id = token
				end
			end
		end
	end

	if not category_id and weapon_id then
		category_id = self.catalog.weapon_to_category[weapon_id]
	end

	local chain = {}
	local seen = {}
	local function push(scope_key)
		if scope_key and not seen[scope_key] then
			seen[scope_key] = true
			insert(chain, scope_key)
		end
	end

	push(weapon_id and make_scope_key("weapon", weapon_id) or nil)
	push(category_id and make_scope_key("category", category_id) or nil)
	push(self.catalog.global.key)
	return chain
end

function ScopeSidebar:ResolveFlag(flag, context, use_defaults)
	local token = tostring(flag or "")
	if token == "" then
		return nil
	end

	for _, scope_key in ipairs(self:_get_chain(context)) do
		local values = self.scope_values[scope_key]
		if type(values) == "table" and values[token] ~= nil then
			return deep_copy(values[token]), self.scope_lookup[scope_key] or self.catalog.by_key[scope_key]
		end
	end

	if use_defaults == false then
		return nil
	end

	local entry = self.flag_entries[token]
	if entry then
		return deep_copy(entry.default_serialized), nil
	end

	return nil
end

ScopeSidebar.GetResolvedFlag = ScopeSidebar.ResolveFlag
ScopeSidebar.GetValue = ScopeSidebar.ResolveFlag

function ScopeSidebar:_snapshot_controls()
	if self._skip_snapshot then
		return
	end
	local scope_key = self.active_scope_key
	if not scope_key or #self.bound_controls == 0 then
		return
	end
	local bucket = self:_ensure_scope_values(scope_key)
	for _, bound in ipairs(self.bound_controls) do
		bucket[bound.flag] = deep_copy(scope_get_value(bound.entry, false))
	end
end

function ScopeSidebar:_load_controls(fire_callback)
	local scope_key = self.active_scope_key or self.catalog.global.key
	local bucket = self.scope_values[scope_key]
	self._refreshing_controls = true
	for _, bound in ipairs(self.bound_controls) do
		local stored
		if type(bucket) == "table" and bucket[bound.flag] ~= nil then
			stored = deep_copy(bucket[bound.flag])
		else
			stored = deep_copy(bound.default_serialized)
		end
		scope_apply_value(bound.entry, stored, false)
	end
	self._refreshing_controls = false
end

function ScopeSidebar:_capture_single(flag)
	if self._refreshing_controls then
		return
	end
	local scope_key = self.active_scope_key
	if not scope_key then
		return
	end
	local bound = self.flag_entries[flag]
	if not bound then
		return
	end
	local bucket = self:_ensure_scope_values(scope_key)
	bucket[flag] = deep_copy(scope_get_value(bound.entry, false))
end

function ScopeSidebar:_register_bound_control(raw_control)
	local entry = raw_control and raw_control.search_entry
	local flag = entry and entry.flag or nil
	if not entry or not flag then
		return raw_control
	end

	local bound = {
		flag = flag,
		control = raw_control,
		entry = entry,
		default_serialized = deep_copy(scope_get_value(entry, true)),
	}

	entry.skip_config = true
	self.flag_entries[flag] = bound
	insert(self.bound_controls, bound)

	local scope_key = self.active_scope_key or self.catalog.global.key
	local bucket = self:_ensure_scope_values(scope_key)
	if bucket[flag] == nil then
		bucket[flag] = deep_copy(bound.default_serialized)
	end

	self._refreshing_controls = true
	scope_apply_value(entry, deep_copy(bucket[flag]), false)
	self._refreshing_controls = false

	raw_control._scope_manager = self

	return create_scoped_control_wrapper(raw_control)
end

function ScopeSidebar:SelectScope(scope_ref, fire_callback)
	local scope = self:GetScope(scope_ref) or self:AddScope(scope_ref, false)
	if not scope then
		scope = self.catalog.global
		self.scope_lookup[scope.key] = scope
	end

	self:_snapshot_controls()

	self.active_scope_key = scope.key

	local bucket = self:_ensure_scope_values(scope.key)
	for _, bound in ipairs(self.bound_controls) do
		if bucket[bound.flag] == nil then
			bucket[bound.flag] = deep_copy(bound.default_serialized)
		end
	end

	self:_rebuild_sidebar_rows()
	self:_load_controls(fire_callback)

	return scope
end

function ScopeSidebar:GetConfigValue(use_defaults)
	local payload = {
		version = 1,
		selected = self.catalog.global.key,
		scopes = {
			{
				kind = self.catalog.global.kind,
				id = self.catalog.global.id,
				name = self.catalog.global.name,
				order = self.catalog.global.order,
			},
		},
		values = {},
	}

	if use_defaults then
		return payload
	end

	self:_snapshot_controls()

	payload.selected = self.active_scope_key or self.catalog.global.key
	payload.scopes = {}
	for _, scope in ipairs(self:_get_sorted_scopes()) do
		insert(payload.scopes, {
			kind = scope.kind,
			id = scope.id,
			name = scope.name,
			category_id = scope.category_id,
			order = scope.order,
		})
	end

	for scope_key, values in pairs(self.scope_values) do
		if type(values) == "table" and next(values) ~= nil then
			payload.values[scope_key] = deep_copy(values)
		end
	end

	return payload
end

function ScopeSidebar:ApplyConfigValue(value, fire_callback)
	local payload = type(value) == "table" and value or {}
	self.scope_lookup = {}
	self.scope_values = {}
	self.scope_lookup[self.catalog.global.key] = deep_copy(self.catalog.global)

	if type(payload.scopes) == "table" then
		for _, raw_scope in ipairs(payload.scopes) do
			self:AddScope(raw_scope, false)
		end
	end

	if type(payload.values) == "table" then
		for scope_key, values in pairs(payload.values) do
			if type(values) == "table" then
				self.scope_values[scope_key] = deep_copy(values)
			end
		end
	end

	self:_rebuild_sidebar_rows()

	self._skip_snapshot = true
	self:SelectScope(payload.selected or self.catalog.global.key, fire_callback == true)
	self._skip_snapshot = false
end

function ScopeSidebar:AddSection(options)
	local raw_section = self.tab:AddSection(options)
	return create_scoped_section_wrapper(self, raw_section)
end

function ScopeSidebar:BindSection(section)
	if type(section) == "table" and section.section and section.manager == self then
		return section
	end
	return create_scoped_section_wrapper(self, section)
end

function ScopedSection:_wrap_control(method_name, options)
	local raw_options = shallow_copy(normalize(options, "Name"))
	local user_callback = raw_options.Callback
	local manager = self.manager
	local captured_flag = raw_options.Flag or raw_options.Name

	if raw_options.AttachTo and type(raw_options.AttachTo) == "table" and raw_options.AttachTo.__raw_control then
		raw_options.AttachTo = raw_options.AttachTo.__raw_control
	end

	raw_options.SkipConfig = true
	raw_options.Callback = function(...)
		if captured_flag then
			manager:_capture_single(captured_flag)
		end
		if user_callback then
			return user_callback(...)
		end
	end

	local raw_control = self.section[method_name](self.section, raw_options)
	captured_flag = raw_control.flag or captured_flag
	return manager:_register_bound_control(raw_control)
end

