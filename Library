	local function refresh_popup_position()
		local root_pos = self.window.root.AbsolutePosition
		local root_size = self.window.root.AbsoluteSize
		local hitbox_pos = picker.hitbox.AbsolutePosition
		local hitbox_size = picker.hitbox.AbsoluteSize
		local rel_x = hitbox_pos.X - root_pos.X + hitbox_size.X + 8
		local rel_y = hitbox_pos.Y - root_pos.Y
		if rel_x + popup_width > root_size.X - 6 then
			rel_x = (hitbox_pos.X - root_pos.X) - popup_width - 8
		end
		rel_x = clamp(rel_x, 6, max(6, root_size.X - popup_width - 6))
		rel_y = clamp(rel_y, 6, max(6, root_size.Y - popup_height - 6))
		popup.Position = UDim2.fromOffset(rel_x, rel_y)
	end

